---
// omux — one durable terminal session. A project-scoped command and its
// scrollback appear in a single wide window; the quiet pulse is the only
// persistent signal that the process is still live.
// Standard canvas: 240×144, 10s master loop, 2s live pulse nested inside.
---

<svg
	viewBox="0 0 240 144"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<g class="terminal">
		<rect x="30" y="18" width="180" height="108" rx="5" stroke="currentColor" stroke-width="1.25"
		></rect>

		<!-- The agent shares the console body; there is no reserved title bar. -->
		<g fill="var(--accent)">
			<circle cx="196" cy="31" r="2"></circle>
			<circle
				class="live-ring"
				cx="196"
				cy="31"
				r="5"
				fill="none"
				stroke="var(--accent)"
				opacity="0"></circle>
		</g>

		<!-- Four console rows share a baseline rhythm and a prompt-width gutter. -->
		<g class="console-line line-1">
			<path d="M 43 28 L 47 32 L 43 36" stroke="var(--accent)" stroke-width="1.25"></path>
			<g stroke="currentColor" stroke-width="2">
				<line x1="54" y1="32" x2="84" y2="32" opacity="0.7"></line>
				<line x1="90" y1="32" x2="124" y2="32" opacity="0.3"></line>
				<line x1="130" y1="32" x2="161" y2="32" opacity="0.3"></line>
			</g>
		</g>
		<g class="console-line line-2" stroke="currentColor" stroke-width="2">
			<line x1="54" y1="53" x2="104" y2="53" opacity="0.7"></line>
			<line x1="111" y1="53" x2="149" y2="53" opacity="0.3"></line>
		</g>
		<g class="console-line line-3" stroke="currentColor" stroke-width="2">
			<line x1="54" y1="74" x2="124" y2="74" opacity="0.7"></line>
			<line x1="131" y1="74" x2="185" y2="74" opacity="0.3"></line>
		</g>
		<g class="console-line line-4" stroke="currentColor" stroke-width="2">
			<line x1="54" y1="95" x2="111" y2="95" opacity="0.7"></line>
			<line x1="118" y1="95" x2="166" y2="95" opacity="0.3"></line>
		</g>

		<!-- tmux footer: project, command, and live process state. -->
		<line x1="30" y1="105" x2="210" y2="105" stroke="currentColor" opacity="0.3"></line>
		<g stroke-width="2">
			<line x1="41" y1="115" x2="76" y2="115" stroke="var(--accent)"></line>
			<line x1="84" y1="115" x2="126" y2="115" stroke="currentColor" opacity="0.3"></line>
			<line x1="134" y1="115" x2="164" y2="115" stroke="currentColor" opacity="0.3"></line>
		</g>
	</g>
</svg>

<style>
	/* Static fallback: a complete, quiet terminal. Motion only establishes the
	   window and lets its evenly spaced scrollback arrive in sequence. */
	@media (prefers-reduced-motion: no-preference) {
		.terminal {
			transform-box: fill-box;
			transform-origin: center;
			animation: omx-terminal 10s ease-in-out infinite;
		}
		.console-line {
			animation: omx-line-1 10s ease-out infinite;
		}
		.line-2 {
			animation-name: omx-line-2;
		}
		.line-3 {
			animation-name: omx-line-3;
		}
		.line-4 {
			animation-name: omx-line-4;
		}
		.live-ring {
			transform-box: fill-box;
			transform-origin: center;
			animation: omx-live 2s ease-out infinite;
		}

		@keyframes omx-terminal {
			0% {
				transform: translateY(3px);
				opacity: 0;
			}
			8%,
			92% {
				transform: translateY(0);
				opacity: 1;
			}
			98%,
			100% {
				transform: translateY(0);
				opacity: 0;
			}
		}
		@keyframes omx-line-1 {
			0%,
			12% {
				opacity: 0;
			}
			18%,
			100% {
				opacity: 1;
			}
		}
		@keyframes omx-line-2 {
			0%,
			24% {
				opacity: 0;
			}
			30%,
			100% {
				opacity: 1;
			}
		}
		@keyframes omx-line-3 {
			0%,
			36% {
				opacity: 0;
			}
			42%,
			100% {
				opacity: 1;
			}
		}
		@keyframes omx-line-4 {
			0%,
			48% {
				opacity: 0;
			}
			54%,
			100% {
				opacity: 1;
			}
		}
		@keyframes omx-live {
			0% {
				transform: scale(0.5);
				opacity: 0.5;
			}
			75%,
			100% {
				transform: scale(1.7);
				opacity: 0;
			}
		}
	}
</style>
