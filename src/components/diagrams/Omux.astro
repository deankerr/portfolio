---
// omux — one terminal, two operators. A single tmux window sits between a
// human (circle) and an agent (square); each sends a command in, the same
// output lands in the shared scrollback, and both watch it happen. The
// window is the meeting point — neither side owns it.
// Standard canvas: 240×144, 8s master loop, 1s cursor blink nested inside.
---

<svg
	viewBox="0 0 240 144"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the shared window -->
	<rect x="72" y="26" width="96" height="92" rx="4" stroke="currentColor" stroke-width="1.25"
	></rect>
	<line x1="72" y1="98" x2="168" y2="98" stroke="currentColor" stroke-width="1" opacity="0.3"
	></line>

	<!-- scrollback — always mid-stream -->
	<g stroke="currentColor" stroke-width="2">
		<line x1="80" y1="40" x2="120" y2="40" opacity="0.9"></line>
		<line x1="80" y1="50" x2="144" y2="50" opacity="0.5"></line>
		<line x1="80" y1="60" x2="132" y2="60" opacity="0.35"></line>
		<line class="out l1" x1="80" y1="70" x2="138" y2="70" opacity="0.5"></line>
		<line class="out l2" x1="80" y1="80" x2="116" y2="80" opacity="0.5"></line>
	</g>
	<rect class="cursor" x="80" y="86" width="5" height="9" fill="var(--accent)"></rect>

	<!-- status bar — deterministic session ticks; the active one is accent -->
	<g stroke-width="2">
		<line x1="80" y1="108" x2="96" y2="108" stroke="var(--accent)"></line>
		<line x1="102" y1="108" x2="118" y2="108" stroke="currentColor" opacity="0.35"></line>
		<line x1="124" y1="108" x2="140" y2="108" stroke="currentColor" opacity="0.35"></line>
	</g>

	<!-- the operators: human left, agent right -->
	<circle cx="28" cy="72" r="5" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
	></circle>
	<rect x="198" y="66" width="12" height="12" rx="3" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
	></rect>

	<!-- both hold the same line to the same window -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="3 5" opacity="0.3">
		<line x1="36" y1="72" x2="68" y2="72"></line>
		<line x1="194" y1="72" x2="172" y2="72"></line>
	</g>

	<!-- commands in, and the watching rings when output lands -->
	<circle class="cmd h" r="2.5" fill="var(--accent)" opacity="0"></circle>
	<circle class="cmd a" r="2.5" fill="var(--accent)" opacity="0"></circle>
	<circle class="see" cx="28" cy="72" r="9" stroke="var(--accent)" stroke-width="1" opacity="0"
	></circle>
	<circle class="see" cx="204" cy="72" r="9" stroke="var(--accent)" stroke-width="1" opacity="0"
	></circle>
</svg>

<style>
	.cmd.h {
		offset-path: path('M 36 72 L 68 72');
	}
	.cmd.a {
		offset-path: path('M 194 72 L 172 72');
	}

	/* Full shorthand, name included — a nameless base rule gets minified to
	   `animation: none`. Static fallback: the full window with both operators.
	   8s master: human command → output line, agent command → output line;
	   both rings pulse whenever the shared scrollback moves. */
	@media (prefers-reduced-motion: no-preference) {
		.cmd.h {
			animation: omx-cmdh 8s linear infinite;
		}
		.cmd.a {
			animation: omx-cmda 8s linear infinite;
		}
		.l1 {
			animation: omx-l1 8s linear infinite;
		}
		.l2 {
			animation: omx-l2 8s linear infinite;
		}
		.see {
			animation: omx-see 8s linear infinite;
		}
		/* 1s blink divides the 8s master — every loop lands in phase. */
		.cursor {
			animation: omx-blink 1s steps(1) infinite;
		}

		@keyframes omx-cmdh {
			0%,
			6% {
				offset-distance: 0%;
				opacity: 0;
			}
			9% {
				opacity: 1;
			}
			14% {
				opacity: 1;
			}
			16%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes omx-cmda {
			0%,
			40% {
				offset-distance: 0%;
				opacity: 0;
			}
			43% {
				opacity: 1;
			}
			48% {
				opacity: 1;
			}
			50%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes omx-l1 {
			0%,
			17% {
				opacity: 0;
			}
			19%,
			90% {
				opacity: 0.5;
			}
			95%,
			100% {
				opacity: 0;
			}
		}
		@keyframes omx-l2 {
			0%,
			51% {
				opacity: 0;
			}
			53%,
			90% {
				opacity: 0.5;
			}
			95%,
			100% {
				opacity: 0;
			}
		}
		/* two pulses per loop — one per landed line, both observers together */
		@keyframes omx-see {
			0%,
			19% {
				opacity: 0;
			}
			23% {
				opacity: 0.6;
			}
			30%,
			53% {
				opacity: 0;
			}
			57% {
				opacity: 0.6;
			}
			64%,
			100% {
				opacity: 0;
			}
		}
		@keyframes omx-blink {
			0%,
			100% {
				opacity: 1;
			}
			50% {
				opacity: 0;
			}
		}
	}
</style>
