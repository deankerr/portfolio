---
// omux — a tmux window: one live pane with a blinking accent cursor, and a
// crashed pane that stays visible (remain-on-exit) with its accent ✕ and a
// faded status line. Session ticks along the bottom; the active one is accent.
---

<svg
	viewBox="0 0 280 210"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- Window chrome and pane splits. -->
	<g stroke="currentColor" stroke-width="1.25">
		<rect x="18" y="20" width="244" height="140" rx="6"></rect>
		<line x1="150" y1="20" x2="150" y2="160" stroke-width="1"></line>
		<line x1="150" y1="96" x2="262" y2="96" stroke-width="1"></line>
	</g>

	<!-- Left pane — a long-running process, output as abstract lines. -->
	<g stroke="currentColor" stroke-width="2">
		<line x1="30" y1="38" x2="86" y2="38" opacity="0.9"></line>
		<line x1="30" y1="50" x2="114" y2="50" opacity="0.5"></line>
		<line x1="30" y1="62" x2="100" y2="62" opacity="0.5"></line>
		<line x1="30" y1="74" x2="120" y2="74" opacity="0.35"></line>
		<line x1="30" y1="86" x2="94" y2="86" opacity="0.5"></line>
		<line x1="30" y1="98" x2="108" y2="98" opacity="0.35"></line>
		<line x1="30" y1="110" x2="74" y2="110" opacity="0.5"></line>
	</g>
	<rect class="cursor" x="30" y="122" width="7" height="12" fill="var(--accent)"></rect>

	<!-- Right top pane — another session, still running. -->
	<g stroke="currentColor" stroke-width="2">
		<line x1="162" y1="38" x2="210" y2="38" opacity="0.9"></line>
		<line x1="162" y1="50" x2="228" y2="50" opacity="0.5"></line>
		<line x1="162" y1="62" x2="218" y2="62" opacity="0.35"></line>
		<line x1="162" y1="74" x2="192" y2="74" opacity="0.5"></line>
	</g>

	<!-- Right bottom pane — crashed, but held on screen with its exit status. -->
	<g stroke="currentColor" stroke-width="2" opacity="0.3">
		<line x1="162" y1="112" x2="222" y2="112"></line>
		<line x1="162" y1="124" x2="204" y2="124"></line>
	</g>
	<g stroke="var(--accent)" stroke-width="1.75">
		<line x1="164" y1="138" x2="174" y2="148"></line>
		<line x1="174" y1="138" x2="164" y2="148"></line>
	</g>
	<line x1="184" y1="143" x2="216" y2="143" stroke="currentColor" stroke-width="2" opacity="0.3"
	></line>

	<!-- Status bar — deterministic session names as ticks; active is accent. -->
	<g stroke-width="2">
		<line x1="26" y1="174" x2="50" y2="174" stroke="var(--accent)"></line>
		<line x1="60" y1="174" x2="84" y2="174" stroke="currentColor" opacity="0.4"></line>
		<line x1="94" y1="174" x2="118" y2="174" stroke="currentColor" opacity="0.4"></line>
	</g>
</svg>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.cursor {
			animation: omx-blink 1.15s steps(1) infinite;
		}
		@keyframes omx-blink {
			0%,
			100% {
				opacity: 1;
			}
			50% {
				opacity: 0;
			}
		}
	}
</style>
