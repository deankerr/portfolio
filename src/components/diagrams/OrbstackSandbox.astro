---
// orbstack-sandbox — the seatbelt, worn calmly. The host's world (hatched
// mounts: real contents) maps into the VM, but inside the sandbox boundary —
// which draws itself closed each cycle — the same mounts arrive as empty
// tmpfs. The agent works quietly in its corner; nothing collides, nothing
// escapes, the world outside never changes.
// Standard canvas: 240×144, 8s master loop, 2s cursor breath nested inside.
---

<svg
	viewBox="0 0 240 144"
	fill="none"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<defs>
		<pattern
			id="osx-hatch"
			width="6"
			height="6"
			patternTransform="rotate(45)"
			patternUnits="userSpaceOnUse"
		>
			<line x1="0" y1="0" x2="0" y2="6" stroke="currentColor" stroke-width="1" opacity="0.45"
			></line>
		</pattern>
	</defs>

	<!-- the world: host mounts with real contents — untouched, always -->
	<g stroke="currentColor" stroke-width="1.25" stroke-linecap="round" fill="url(#osx-hatch)">
		<rect x="16" y="32" width="40" height="20" rx="3"></rect>
		<rect x="16" y="62" width="40" height="20" rx="3"></rect>
		<rect x="16" y="92" width="40" height="20" rx="3"></rect>
	</g>

	<!-- the VM -->
	<rect x="88" y="20" width="140" height="104" rx="6" stroke="currentColor" stroke-width="1.25"
	></rect>

	<!-- mount paths crossing in -->
	<g stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-dasharray="1.5 4" opacity="0.3">
		<line x1="56" y1="42" x2="110" y2="47"></line>
		<line x1="56" y1="72" x2="110" y2="73"></line>
		<line x1="56" y1="102" x2="110" y2="99"></line>
	</g>

	<!-- the namespace boundary, drawn closed each cycle -->
	<rect
		class="wall"
		x="100"
		y="32"
		width="116"
		height="80"
		rx="5"
		stroke="var(--accent)"
		stroke-width="1"
		opacity="0.7"></rect>

	<!-- the same mounts inside — empty tmpfs, nothing to read -->
	<g class="empty" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-dasharray="3 4" opacity="0.55">
		<rect x="112" y="38" width="40" height="18" rx="3"></rect>
		<rect x="112" y="64" width="40" height="18" rx="3"></rect>
		<rect x="112" y="90" width="40" height="18" rx="3"></rect>
	</g>

	<!-- the agent, working quietly in its corner -->
	<g stroke="currentColor" stroke-width="2" stroke-linecap="round">
		<line class="work w1" x1="166" y1="46" x2="196" y2="46" opacity="0.45"></line>
		<line class="work w2" x1="166" y1="56" x2="188" y2="56" opacity="0.35"></line>
		<line class="work w3" x1="166" y1="66" x2="200" y2="66" opacity="0.45"></line>
	</g>
	<rect class="calm" x="166" y="74" width="5" height="8" fill="var(--accent)" opacity="0.8"></rect>
</svg>

<style>
	/* Full shorthand, name included — a nameless base rule gets minified to
	   `animation: none`. Static fallback: the whole arrangement at rest.
	   8s master: the boundary draws closed, the mounts empty out, the agent
	   quietly gets on with it. Perimeter ≈ 392. */
	@media (prefers-reduced-motion: no-preference) {
		.wall {
			stroke-dasharray: 392;
			animation: osx-wall 8s linear infinite;
		}
		.empty {
			animation: osx-empty 8s linear infinite;
		}
		.w1 {
			animation: osx-w1 8s linear infinite;
		}
		.w2 {
			animation: osx-w2 8s linear infinite;
		}
		.w3 {
			animation: osx-w3 8s linear infinite;
		}
		/* a slow breath, not a blink — 2s divides the 8s master */
		.calm {
			animation: osx-calm 2s ease-in-out infinite;
		}

		@keyframes osx-wall {
			0% {
				stroke-dashoffset: 392;
				opacity: 0.7;
			}
			16% {
				stroke-dashoffset: 0;
			}
			92% {
				stroke-dashoffset: 0;
				opacity: 0.7;
			}
			97%,
			100% {
				stroke-dashoffset: 0;
				opacity: 0;
			}
		}
		@keyframes osx-empty {
			0%,
			17% {
				opacity: 0;
			}
			26%,
			92% {
				opacity: 0.55;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
		@keyframes osx-w1 {
			0%,
			34% {
				opacity: 0;
			}
			37%,
			92% {
				opacity: 0.45;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
		@keyframes osx-w2 {
			0%,
			46% {
				opacity: 0;
			}
			49%,
			92% {
				opacity: 0.35;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
		@keyframes osx-w3 {
			0%,
			58% {
				opacity: 0;
			}
			61%,
			92% {
				opacity: 0.45;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
		@keyframes osx-calm {
			0%,
			100% {
				opacity: 0.8;
			}
			50% {
				opacity: 0.3;
			}
		}
	}
</style>
