---
// orbstack-sandbox — host mounts (hatched: they have contents) map into the
// VM, but inside the dashed sandbox boundary they arrive as empty tmpfs
// (dashed, hollow). The accent dot rides the middle mount toward the sandbox
// and is extinguished at the boundary.
---

<svg
	viewBox="0 0 280 210"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<defs>
		<pattern
			id="osx-hatch"
			width="6"
			height="6"
			patternTransform="rotate(45)"
			patternUnits="userSpaceOnUse"
		>
			<line x1="0" y1="0" x2="0" y2="6" stroke="currentColor" stroke-width="1" opacity="0.45"
			></line>
		</pattern>
	</defs>

	<!-- Host mounts — home, config, credentials. Hatch = real contents. -->
	<g stroke="currentColor" stroke-width="1.25" fill="url(#osx-hatch)">
		<rect x="28" y="48" width="46" height="26" rx="3"></rect>
		<rect x="28" y="88" width="46" height="26" rx="3"></rect>
		<rect x="28" y="128" width="46" height="26" rx="3"></rect>
	</g>

	<!-- The VM, and the sandbox user's mount namespace inside it. -->
	<rect x="118" y="26" width="140" height="158" rx="8" stroke="currentColor" stroke-width="1.25"
	></rect>
	<rect
		x="134"
		y="42"
		width="108"
		height="126"
		rx="6"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="5 5"
		opacity="0.8"></rect>

	<!-- Mount paths crossing into the VM. -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="1.5 4" opacity="0.35">
		<line x1="74" y1="61" x2="152" y2="70"></line>
		<line x1="74" y1="101" x2="152" y2="110"></line>
		<line x1="74" y1="141" x2="152" y2="150"></line>
	</g>

	<!-- The same mounts inside the sandbox — empty tmpfs, nothing to read. -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="3 4" opacity="0.55">
		<rect x="152" y="58" width="46" height="24" rx="3"></rect>
		<rect x="152" y="98" width="46" height="24" rx="3"></rect>
		<rect x="152" y="138" width="46" height="24" rx="3"></rect>
	</g>

	<!-- Host data heading for the sandbox, stopped at the namespace boundary. -->
	<circle class="blocked" r="3" fill="var(--accent)"></circle>
</svg>

<style>
	.blocked {
		opacity: 0;
	}
	@media (prefers-reduced-motion: no-preference) {
		.blocked {
			animation: osx-block 4.2s ease-in-out infinite;
		}
		/* The boundary sits at x=134 — the dot dies right there. */
		@keyframes osx-block {
			0% {
				transform: translate(74px, 101px);
				opacity: 0;
			}
			10% {
				opacity: 1;
			}
			58% {
				transform: translate(134px, 108px);
				opacity: 1;
			}
			66%,
			100% {
				transform: translate(137px, 108.4px);
				opacity: 0;
			}
		}
	}
</style>
