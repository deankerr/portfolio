---
// orbstack-sandbox — a full-stack workspace inside one private namespace.
// Independent web, API, and worker builds fill the namespace; their square
// packets leave through matching apertures at the lane ends.
// Standard canvas: 240×144, 9s boundary loop; work loops stay independent.
---

<svg
	viewBox="0 0 240 144"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- The sole enclosure: the agent's private mount namespace. -->
	<rect
		class="wall"
		x="41"
		y="12"
		width="158"
		height="120"
		rx="6"
		stroke="var(--accent)"
		stroke-width="1.25"
		opacity="0.68"></rect>

	<g class="sandbox-work" transform="translate(-29 0)">
		<!-- The agent owns the workspace, but does not become another container. -->
		<g>
			<circle cx="86" cy="24" r="2.25" fill="var(--accent)"></circle>
			<circle
				class="agent-ring"
				cx="86"
				cy="24"
				r="5.5"
				stroke="var(--accent)"
				stroke-width="1"
				opacity="0"></circle>
			<line x1="95" y1="24" x2="116" y2="24" stroke="currentColor" stroke-width="1.5" opacity="0.3"
			></line>
		</g>

		<!-- Three restrained build lanes: web, API, and worker. -->
		<g stroke="currentColor" stroke-width="1" fill="var(--surface)">
			<g>
				<rect x="85" y="35" width="128" height="18" rx="3"></rect>
				<rect x="92" y="41" width="7" height="6" rx="1" opacity="0.35"></rect>
				<line x1="106" y1="44" x2="190" y2="44" opacity="0.2"></line>
				<rect x="200" y="41" width="6" height="6" fill="none" opacity="0.22"></rect>
			</g>
			<g>
				<rect x="85" y="69" width="128" height="18" rx="3"></rect>
				<circle cx="95.5" cy="78" r="3" opacity="0.35"></circle>
				<line x1="106" y1="78" x2="190" y2="78" opacity="0.2"></line>
				<rect x="200" y="75" width="6" height="6" fill="none" opacity="0.22"></rect>
			</g>
			<g>
				<rect x="85" y="103" width="128" height="18" rx="3"></rect>
				<path d="M 92 109 H 99 M 92 112 H 99 M 92 115 H 99" opacity="0.35"></path>
				<line x1="106" y1="112" x2="190" y2="112" opacity="0.2"></line>
				<rect x="200" y="109" width="6" height="6" fill="none" opacity="0.22"></rect>
			</g>
		</g>

		<!-- Build packets move independently; no architectural wiring required. -->
		<g fill="currentColor">
			<rect class="packet p1" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
			<rect class="packet p2" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
			<rect class="packet p3" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		</g>
	</g>
</svg>

<style>
	.p1 {
		offset-path: path('M 106 44 L 203 44');
	}
	.p2 {
		offset-path: path('M 106 78 L 203 78');
	}
	.p3 {
		offset-path: path('M 106 112 L 203 112');
	}

	/* Static fallback: the namespace is closed and all three build lanes are
	   present. Motion overlaps their arrival with the final boundary stroke. */
	@media (prefers-reduced-motion: no-preference) {
		.wall {
			stroke-dasharray: 548;
			animation: osx-wall 9s linear infinite;
		}
		.sandbox-work {
			animation: osx-work 9s ease-out infinite;
		}
		.agent-ring {
			transform-box: fill-box;
			transform-origin: center;
			animation: osx-agent 3s ease-out infinite;
		}
		.packet {
			animation: osx-packet 3.8s linear infinite -1.1s;
		}
		.p2 {
			animation-duration: 4.9s;
			animation-delay: -3.2s;
		}
		.p3 {
			animation-duration: 4.3s;
			animation-delay: -2.4s;
		}

		@keyframes osx-wall {
			0% {
				stroke-dashoffset: 548;
				opacity: 0.68;
			}
			24%,
			92% {
				stroke-dashoffset: 0;
				opacity: 0.68;
			}
			97%,
			100% {
				stroke-dashoffset: 0;
				opacity: 0;
			}
		}
		@keyframes osx-work {
			0%,
			10% {
				opacity: 0;
			}
			16% {
				opacity: 0.35;
			}
			29%,
			92% {
				opacity: 1;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
		@keyframes osx-packet {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			10% {
				opacity: 0.85;
			}
			84% {
				offset-distance: 100%;
				opacity: 0.85;
			}
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes osx-agent {
			0% {
				transform: scale(0.5);
				opacity: 0.4;
			}
			75%,
			100% {
				transform: scale(1.8);
				opacity: 0;
			}
		}
	}
</style>
