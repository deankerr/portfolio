---
// archi — a layered module graph, dagre-style: the accent root (the tsconfig
// entry) fans out through import edges. Dashes march down the edges — the
// extraction flowing through the project.
---

<svg
	viewBox="0 0 280 210"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- Import edges, layer by layer. -->
	<g class="flow" stroke="currentColor" stroke-width="1" stroke-dasharray="3 5" opacity="0.45">
		<path d="M 140 39 C 140 57 70 49 70 67"></path>
		<path d="M 140 39 C 140 48 140 58 140 67"></path>
		<path d="M 140 39 C 140 57 210 49 210 67"></path>
		<path d="M 70 85 C 70 103 45 95 45 113"></path>
		<path d="M 70 85 C 70 103 110 95 110 113"></path>
		<path d="M 140 85 C 140 103 110 95 110 113"></path>
		<path d="M 140 85 C 140 103 175 95 175 113"></path>
		<path d="M 210 85 C 210 103 175 95 175 113"></path>
		<path d="M 210 85 C 210 103 240 95 240 113"></path>
		<path d="M 45 131 C 45 151 90 141 90 161"></path>
		<path d="M 110 131 C 110 151 90 141 90 161"></path>
		<path d="M 175 131 C 175 151 190 141 190 161"></path>
		<path d="M 240 131 C 240 151 190 141 190 161"></path>
	</g>

	<!-- Modules — the entry point is accent, everything else discovered. -->
	<rect x="123" y="21" width="34" height="18" rx="4" stroke="var(--accent)" stroke-width="1.25"
	></rect>
	<g stroke="currentColor" stroke-width="1.25">
		<rect x="53" y="67" width="34" height="18" rx="4"></rect>
		<rect x="123" y="67" width="34" height="18" rx="4"></rect>
		<rect x="193" y="67" width="34" height="18" rx="4"></rect>
		<rect x="28" y="113" width="34" height="18" rx="4"></rect>
		<rect x="93" y="113" width="34" height="18" rx="4"></rect>
		<rect x="158" y="113" width="34" height="18" rx="4"></rect>
		<rect x="223" y="113" width="34" height="18" rx="4"></rect>
		<rect x="73" y="161" width="34" height="18" rx="4"></rect>
		<rect x="173" y="161" width="34" height="18" rx="4"></rect>
	</g>
</svg>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.flow {
			/* One dash period is 8 — a full multiple keeps the loop seamless. */
			animation: arc-flow 2.2s linear infinite;
		}
		@keyframes arc-flow {
			to {
				stroke-dashoffset: -16;
			}
		}
	}
</style>
