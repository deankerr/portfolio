---
// ig · diffusion — a noisy seven-row field resolves into a complete diamond
// outline. The faint interior remains part of the same field: structure
// emerges from noise rather than arriving as a separate object.

const columns = Array.from({ length: 11 }, (_, index) => 36 + index * 16);
const rows = Array.from({ length: 7 }, (_, index) => 20 + index * 16);
const opacity = [0.12, 0.2, 0.3, 0.42];

const noise = rows.flatMap((y, row) =>
	columns.map((x, column) => ({
		x,
		y,
		group: (column + row * 2) % 3,
		opacity: opacity[(column * 3 + row * 5) % opacity.length],
	})),
);

const outline = [
	[5, 0],
	[4, 1],
	[6, 1],
	[3, 2],
	[7, 2],
	[2, 3],
	[8, 3],
	[3, 4],
	[7, 4],
	[4, 5],
	[6, 5],
	[5, 6],
];

const interior = [
	[5, 1],
	[4, 2],
	[5, 2],
	[6, 2],
	[3, 3],
	[4, 3],
	[5, 3],
	[6, 3],
	[7, 3],
	[4, 4],
	[5, 4],
	[6, 4],
	[5, 5],
];
---

<svg viewBox="0 0 240 144" fill="none" aria-hidden="true" class="w-full">
	<g class="noise">
		{
			[0, 1, 2].map((group) => (
				<g class={`flicker flicker-${group + 1}`} fill="currentColor">
					{noise
						.filter((cell) => cell.group === group)
						.map((cell) => (
							<rect x={cell.x} y={cell.y} width="8" height="8" rx="1.25" opacity={cell.opacity} />
						))}
				</g>
			))
		}
	</g>

	<g class="resolved" opacity="0">
		<g fill="currentColor" opacity="0.28">
			{
				interior.map(([column, row]) => (
					<rect x={columns[column]} y={rows[row]} width="8" height="8" rx="1.25" />
				))
			}
		</g>
		<g fill="var(--accent)">
			{
				outline.map(([column, row]) => (
					<rect x={columns[column]} y={rows[row]} width="8" height="8" rx="1.25" />
				))
			}
		</g>
	</g>
</svg>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.noise {
			animation: hero-df-noise 9s linear infinite;
		}
		.resolved {
			animation: hero-df-form 9s linear infinite;
		}
		.flicker {
			animation: hero-df-flicker 0.9s ease-in-out infinite;
		}
		.flicker-2 {
			animation-delay: 0.3s;
		}
		.flicker-3 {
			animation-delay: 0.6s;
		}

		@keyframes hero-df-noise {
			0%,
			15% {
				opacity: 1;
			}
			70%,
			86% {
				opacity: 0.14;
			}
			96%,
			100% {
				opacity: 1;
			}
		}
		@keyframes hero-df-form {
			0%,
			15% {
				opacity: 0;
			}
			70%,
			86% {
				opacity: 1;
			}
			96%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hero-df-flicker {
			0%,
			100% {
				opacity: 1;
			}
			50% {
				opacity: 0.52;
			}
		}
	}
</style>
