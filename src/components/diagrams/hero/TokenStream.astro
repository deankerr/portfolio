---
// token stream — the output. Four lines of text-shaped bars type themselves
// in behind a gliding caret; the last line stops mid-thought and the caret
// blinks at idle. Streaming inference as everyone who has watched a model
// answer knows it.

const lines = [
	{ y: 36, widths: [30, 22, 38, 18, 26] },
	{ y: 60, widths: [26, 34, 18, 30] },
	{ y: 84, widths: [20, 30, 24, 16, 34] },
	{ y: 108, widths: [28, 16] },
];

// Lay tokens out with an 8-unit gap from a shared left margin.
const layout = lines.map(({ y, widths }) => {
	let x = 24;
	return widths.map((width, index) => {
		const token = { x, y, width, opacity: 0.26 + ((index * 5 + y) % 3) * 0.05 };
		x += width + 8;
		return token;
	});
});
---

<svg viewBox="0 0 240 144" fill="none" aria-hidden="true" class="w-full">
	{
		layout.map((tokens, line) =>
			tokens.map(({ x, y, width, opacity }, index) => (
				<g class={`token tk-${line + 1}-${index + 1}`}>
					<rect x={x} y={y} width={width} height="10" rx="2" fill="currentColor" opacity={opacity} />
				</g>
			)),
		)
	}

	<!-- The caret glides each line, rests mid-line, and blinks. -->
	<rect class="caret" x="24" y="34" width="2" height="14" rx="1" fill="var(--accent)"></rect>
</svg>

