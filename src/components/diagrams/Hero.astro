			<rect class="blip b5" x="233" y="90" width="7" height="7" rx="1.5" opacity="0"></rect>
		</g>
		<line
			class="sweep"
			x1="28"
			y1="40"
			x2="28"
			y2="164"
			stroke="currentColor"
			stroke-width="1"
			stroke-dasharray="3 3"
			opacity="0"></line>
	</g>

	<!-- scene 2 · multiplex bundle -->
	<g class="scene s2" opacity="0">
		<g
			class="flow"
			stroke="currentColor"
			stroke-width="1.25"
			stroke-dasharray="3 6"
			opacity="0.55"
		>
			<path d="M 28 79 C 95 79 105 110 140 110 C 175 110 185 141 252 141"></path>
			<path d="M 28 110 C 100 110 180 110 252 110"></path>
			<path d="M 28 141 C 95 141 105 110 140 110 C 175 110 185 79 252 79"></path>
			<path d="M 28 172 C 95 172 105 110 140 110 C 175 110 185 48 252 48"></path>
		</g>
		<path
			class="flow"
			d="M 28 48 C 95 48 105 110 140 110 C 175 110 185 172 252 172"
			stroke="var(--accent)"
			stroke-width="1.5"
			stroke-dasharray="3 6"
			opacity="0.9"></path>
		<circle cx="140" cy="110" r="5" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
		></circle>
		<g stroke="currentColor" stroke-width="1" fill="var(--surface)" opacity="0.7">
			<circle cx="28" cy="79" r="2.5"></circle>
			<circle cx="28" cy="110" r="2.5"></circle>
			<circle cx="28" cy="141" r="2.5"></circle>
			<circle cx="28" cy="172" r="2.5"></circle>
			<circle cx="252" cy="79" r="2.5"></circle>
			<circle cx="252" cy="110" r="2.5"></circle>
			<circle cx="252" cy="141" r="2.5"></circle>
			<circle cx="252" cy="48" r="2.5"></circle>
		</g>
		<circle cx="28" cy="48" r="2.5" stroke="var(--accent)" stroke-width="1" fill="var(--surface)"
		></circle>
		<circle cx="252" cy="172" r="2.5" stroke="var(--accent)" stroke-width="1" fill="var(--surface)"
		></circle>
		<circle class="travel bundle-path" r="2.75" fill="var(--accent)" opacity="0"></circle>
	</g>

	<!-- scene 3 · dependency cascade -->
	<g class="scene s3" opacity="0">
		<g class="flow" stroke="currentColor" stroke-width="1" stroke-dasharray="3 5" opacity="0.45">
			<line x1="48" y1="105" x2="98" y2="62"></line>
			<line x1="48" y1="105" x2="104" y2="128"></line>
			<line x1="48" y1="105" x2="88" y2="172"></line>
			<line x1="98" y1="62" x2="150" y2="40"></line>
			<line x1="98" y1="62" x2="158" y2="92"></line>
			<line x1="104" y1="128" x2="158" y2="92"></line>
			<line x1="104" y1="128" x2="146" y2="150"></line>
			<line x1="88" y1="172" x2="146" y2="150"></line>
			<line x1="88" y1="172" x2="198" y2="168"></line>
			<line x1="150" y1="40" x2="205" y2="64"></line>
			<line x1="158" y1="92" x2="205" y2="64"></line>
			<line x1="158" y1="92" x2="210" y2="118"></line>
			<line x1="146" y1="150" x2="210" y2="118"></line>
