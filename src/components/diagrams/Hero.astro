---
// Homepage hero reel — the three isolated studies stay independently usable
// in /dev/hero, while this wrapper synchronizes their nine-second loops into
// one 27-second sequence.
import OrcaHistory from './hero/OrcaHistory.astro';
import TetraState from './hero/TetraState.astro';
import Diffusion from './hero/Diffusion.astro';
---

<div
	class="hero-reel relative w-full overflow-hidden"
	style="aspect-ratio: 5 / 3"
	aria-hidden="true"
>
	<div class="hero-scene scene-orca absolute inset-0">
		<OrcaHistory />
	</div>
	<div class="hero-scene scene-tetra absolute inset-0">
		<TetraState />
	</div>
	<div class="hero-scene scene-diffusion absolute inset-0">
		<Diffusion />
	</div>
</div>

<style>
	.hero-scene {
		opacity: 0;
	}
	.scene-orca {
		opacity: 1;
	}

	@media (prefers-reduced-motion: no-preference) {
		.scene-orca {
			animation: hero-reel-orca 27s linear infinite;
		}
		.scene-tetra {
			animation: hero-reel-tetra 27s linear infinite;
		}
		.scene-diffusion {
			animation: hero-reel-diffusion 27s linear infinite;
		}

		@keyframes hero-reel-orca {
			0%,
			30% {
				opacity: 1;
			}
			33%,
			96% {
				opacity: 0;
			}
			100% {
				opacity: 1;
			}
		}
		@keyframes hero-reel-tetra {
			0%,
			30% {
				opacity: 0;
			}
			33%,
			63% {
				opacity: 1;
			}
			66%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hero-reel-diffusion {
			0%,
			63% {
				opacity: 0;
			}
			66%,
			96% {
				opacity: 1;
			}
			100% {
				opacity: 0;
			}
		}
	}
</style>
