---
// Homepage hero reel — how a model works, in three vocabularies: attention
// (arcs over a token row — the mechanism), diffusion (a cell field — the
// generation), token stream (typed lines — the output). Each 9s loop stays
// independently usable in /dev/hero; this wrapper synchronizes them into
// one 27-second sequence.
import Attention from './hero/Attention.astro';
import Diffusion from './hero/Diffusion.astro';
import TokenStream from './hero/TokenStream.astro';
---

<div
	class="hero-reel relative w-full overflow-hidden"
	style="aspect-ratio: 5 / 3"
	aria-hidden="true"
>
	<div class="hero-scene scene-attention absolute inset-0">
		<Attention />
	</div>
	<div class="hero-scene scene-diffusion absolute inset-0">
		<Diffusion />
	</div>
	<div class="hero-scene scene-stream absolute inset-0">
		<TokenStream />
	</div>
</div>

<style>
	.hero-scene {
		opacity: 0;
	}
	.scene-attention {
		opacity: 1;
	}

	@media (prefers-reduced-motion: no-preference) {
		.scene-attention {
			animation: hero-reel-attention 27s linear infinite;
		}
		.scene-diffusion {
			animation: hero-reel-diffusion 27s linear infinite;
		}
		.scene-stream {
			animation: hero-reel-stream 27s linear infinite;
		}

		@keyframes hero-reel-attention {
			0%,
			30% {
				opacity: 1;
			}
			33%,
			96% {
				opacity: 0;
			}
			100% {
				opacity: 1;
			}
		}
		@keyframes hero-reel-diffusion {
			0%,
			30% {
				opacity: 0;
			}
			33%,
			63% {
				opacity: 1;
			}
			66%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hero-reel-stream {
			0%,
			63% {
				opacity: 0;
			}
			66%,
			96% {
				opacity: 1;
			}
			100% {
				opacity: 0;
			}
		}
	}
</style>
