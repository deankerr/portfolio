		<circle class="travel graph-high t2" r="2.75" fill="var(--accent)" opacity="0"></circle>
		<circle cx="48" cy="105" r="5.5" stroke="var(--accent)" stroke-width="1.25" fill="var(--surface)"
		></circle>
		<circle cx="48" cy="105" r="2" fill="var(--accent)"></circle>
	</g>

	<!-- progress ticks -->
	<g stroke="currentColor" stroke-width="2" opacity="0.22">
		<line x1="30" y1="200" x2="46" y2="200"></line>
		<line x1="52" y1="200" x2="68" y2="200"></line>
		<line x1="74" y1="200" x2="90" y2="200"></line>
	</g>
	<g stroke="var(--accent)" stroke-width="2">
		<line class="tick tk1" x1="30" y1="200" x2="46" y2="200" opacity="1"></line>
		<line class="tick tk2" x1="52" y1="200" x2="68" y2="200" opacity="0"></line>
		<line class="tick tk3" x1="74" y1="200" x2="90" y2="200" opacity="0"></line>
	</g>
</svg>

<style>
	/* Travel dots follow their scene's route; paths live here so the markup
	   stays geometry-only. */
	.bundle-path {
		offset-path: path('M 28 48 C 95 48 105 110 140 110 C 175 110 185 172 252 172');
	}
	.graph-low {
		offset-path: path('M 48 105 L 104 128 L 158 92 L 210 118 L 252 90');
	}
	.graph-high {
		offset-path: path('M 48 105 L 98 62 L 150 40 L 205 64 L 252 90');
	}

	/* Static fallback = scene 1's matrix and the first tick; everything else
	   holds its markup opacity, so reduced motion sees one quiet diagram. */
	@media (prefers-reduced-motion: no-preference) {
		/* Full shorthand per class, name included — a nameless `animation: 18s …`
		   base rule gets minified to `animation: none`, silently killing the reel. */
		.s1 {
			animation: hero-s1 18s linear infinite;
		}
		.s2 {
			animation: hero-s2 18s linear infinite;
		}
		.s3 {
			animation: hero-s3 18s linear infinite;
		}
		.tk1 {
			animation: hero-tk1 18s linear infinite;
		}
		.tk2 {
			animation: hero-tk2 18s linear infinite;
		}
		.tk3 {
			animation: hero-tk3 18s linear infinite;
		}
		.sweep {
			animation: hero-sweep 18s linear infinite;
		}
		.blip {
			animation: hero-blip 18s linear infinite;
		}
		.b2 {
			animation-delay: 0.4s;
		}
		.b3 {
			animation-delay: 0.9s;
		}
		.b4 {
			animation-delay: 1.4s;
		}
		.b5 {
			animation-delay: 1.9s;
		}
		.flow {
			/* One dash period is 9 — a full multiple keeps the loop seamless. */
			animation: hero-flow 1.4s linear infinite;
		}
		.travel {
			animation: hero-travel 3.6s linear infinite;
		}
		.t2 {
			animation-delay: 1.8s;
		}
		.ripple {
			transform-box: fill-box;
			transform-origin: center;
			animation: hero-ripple 4.2s linear infinite;
		}
		.ring {
			animation: hero-ring 2.8s ease-in-out infinite;
		}
		.r1 {
			animation-delay: 0.35s;
		}
		.r2 {
			animation-delay: 0.7s;
		}
		.r3 {
			animation-delay: 1.05s;
		}
		.r4 {
			animation-delay: 1.4s;
		}

		/* Scene gates — 3 × ~5.3s windows with a drift-through crossfade. */
		@keyframes hero-s1 {
			0% {
				opacity: 1;
				transform: translateY(0);
			}
			28% {
				opacity: 1;
				transform: translateY(0);
			}
			33% {
				opacity: 0;
				transform: translateY(-6px);
			}
			95% {
				opacity: 0;
				transform: translateY(6px);
			}
			100% {
				opacity: 1;
				transform: translateY(0);
			}
		}
		@keyframes hero-s2 {
			0%,
			28% {
				opacity: 0;
				transform: translateY(6px);
			}
			33%,
			61% {
				opacity: 1;
				transform: translateY(0);
			}
			66%,
			100% {
				opacity: 0;
				transform: translateY(-6px);
			}
		}
		@keyframes hero-s3 {
			0%,
			61% {
				opacity: 0;
				transform: translateY(6px);
			}
			66%,
			95% {
				opacity: 1;
				transform: translateY(0);
			}
			100% {
				opacity: 0;
				transform: translateY(-6px);
			}
		}
		@keyframes hero-tk1 {
			0%,
			28% {
				opacity: 1;
			}
			33%,
			95% {
				opacity: 0;
			}
			100% {
				opacity: 1;
			}
		}
		@keyframes hero-tk2 {
			0%,
			28% {
				opacity: 0;
			}
			33%,
			61% {
				opacity: 1;
			}
			66%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hero-tk3 {
			0%,
			61% {
				opacity: 0;
			}
			66%,
			95% {
				opacity: 1;
			}
			100% {
				opacity: 0;
			}
		}
		@keyframes hero-flow {
			to {
				stroke-dashoffset: -9;
			}
		}
		@keyframes hero-sweep {
			0% {
				transform: translateX(0);
				opacity: 0;
			}
			2% {
				opacity: 0.5;
			}
			26% {
				opacity: 0.5;
			}
			30%,
			100% {
				transform: translateX(216px);
				opacity: 0;
			}
		}
		@keyframes hero-blip {
			0%,
			11% {
				opacity: 0;
			}
			13.5%,
			26% {
				opacity: 1;
			}
			31%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hero-travel {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			10% {
				opacity: 1;
			}
			90% {
				opacity: 1;
			}
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes hero-ring {
			0%,
			100% {
				opacity: 0.55;
			}
			50% {
				opacity: 1;
			}
		}
		@keyframes hero-ripple {
			0% {
				transform: scale(0.3);
				opacity: 0;
			}
			14% {
				opacity: 0.65;
			}
			70%,
			100% {
				transform: scale(2.3);
				opacity: 0;
			}
		}
	}
</style>
