---
// scanner study A · marching dashes — same dashed line, but its dashes
// stream downward as it pans. The scanner reads as running machinery
// instead of a ruler being dragged.
import MatrixField from './MatrixField.astro';
---

<svg
	viewBox="23 34 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<MatrixField />
	<g fill="var(--accent)">
		<rect class="blip" x="79" y="68" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b2" x="145" y="46" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b3" x="189" y="112" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b4" x="123" y="134" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b5" x="233" y="90" width="7" height="7" rx="1.5" opacity="0"></rect>
	</g>
	<line
		class="sweep"
		x1="28"
		y1="40"
		x2="28"
		y2="164"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="3 3"
		opacity="0"></line>
</svg>

<style>
	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Two animations on the line: the 7s pan and a fast
	   dash march (period 6 — a full multiple keeps it seamless). */
	@media (prefers-reduced-motion: no-preference) {
		.sweep {
			animation:
				sma-pan 7s linear infinite,
				sma-march 0.5s linear infinite;
		}
		.blip {
			animation: sma-blip 7s linear infinite;
		}
		.b2 {
			animation-delay: 0.4s;
		}
		.b3 {
			animation-delay: 0.9s;
		}
		.b4 {
			animation-delay: 1.4s;
		}
		.b5 {
			animation-delay: 1.9s;
		}

		@keyframes sma-pan {
			0% {
				transform: translateX(0);
				opacity: 0;
			}
			5% {
				opacity: 0.5;
			}
			70% {
				opacity: 0.5;
			}
			77%,
			100% {
				transform: translateX(216px);
				opacity: 0;
			}
		}
		@keyframes sma-march {
			to {
				stroke-dashoffset: -6;
			}
		}
		@keyframes sma-blip {
			0%,
			24% {
				opacity: 0;
			}
			29%,
			67% {
				opacity: 1;
			}
			80%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
