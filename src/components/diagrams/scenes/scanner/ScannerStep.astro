---
// scanner study D · step cursor — no line at all: a column-wide highlight
// snaps cell to cell like a spreadsheet cursor. Discrete and mechanical;
// blips fire the moment the cursor lands on their column.
import MatrixField from './MatrixField.astro';
---

<svg
	viewBox="23 34 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<MatrixField />
	<g fill="var(--accent)">
		<rect class="blip" x="79" y="68" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b2" x="145" y="46" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b3" x="189" y="112" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b4" x="123" y="134" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b5" x="233" y="90" width="7" height="7" rx="1.5" opacity="0"></rect>
	</g>

	<rect
		class="cursor"
		x="31"
		y="41"
		width="15"
		height="127"
		rx="2.5"
		fill="currentColor"
		opacity="0"></rect>
</svg>

<style>
	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. steps(9, jump-none) lands the cursor on all ten
	   columns; the travel segment ends at 63%, so each dwell is ~0.49s. */
	@media (prefers-reduced-motion: no-preference) {
		.cursor {
			animation: sst-step 7s linear infinite;
		}
		.blip {
			animation: sst-blip 7s linear infinite;
		}
		/* Delays place each blip on its column's landing beat. */
		.b2 {
			animation-delay: 1.47s;
		}
		.b3 {
			animation-delay: 2.45s;
		}
		.b4 {
			animation-delay: 0.98s;
		}
		.b5 {
			animation-delay: 3.43s;
		}

		@keyframes sst-step {
			0% {
				transform: translateX(0);
				opacity: 0.09;
				animation-timing-function: steps(9, jump-none);
			}
			63% {
				transform: translateX(198px);
				opacity: 0.09;
			}
			72%,
			100% {
				transform: translateX(198px);
				opacity: 0;
			}
		}
		@keyframes sst-blip {
			0%,
			13% {
				opacity: 0;
			}
			15%,
			70% {
				opacity: 1;
			}
			80%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
