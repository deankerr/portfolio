---
// scanner study E · wavefront — no instrument at all. The pass is a crest of
// brightness moving through the columns; the field itself carries the scan,
// and the blips ride the crest.
---

<svg
	viewBox="23 34 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the matrix, column by column so the crest can lift each in turn -->
	<g class="col c0" fill="currentColor">
		<rect x="35" y="46" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="35" y="68" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="35" y="90" width="7" height="7" rx="1.5" opacity="0.35"></rect>
		<rect x="35" y="112" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="35" y="134" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="35" y="156" width="7" height="7" rx="1.5" opacity="0.25"></rect>
	</g>
	<g class="col c1" fill="currentColor">
		<rect x="57" y="46" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="57" y="68" width="7" height="7" rx="1.5" opacity="0.35"></rect>
		<rect x="57" y="90" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="57" y="112" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="57" y="134" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="57" y="156" width="7" height="7" rx="1.5" opacity="0.4"></rect>
	</g>
	<g class="col c2" fill="currentColor">
		<rect x="79" y="46" width="7" height="7" rx="1.5" opacity="0.25"></rect>
		<rect x="79" y="68" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="79" y="90" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="79" y="112" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="79" y="134" width="7" height="7" rx="1.5" opacity="0.35"></rect>
		<rect x="79" y="156" width="7" height="7" rx="1.5" opacity="0.15"></rect>
	</g>
	<g class="col c3" fill="currentColor">
		<rect x="101" y="46" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="101" y="68" width="7" height="7" rx="1.5" opacity="0.25"></rect>
		<rect x="101" y="90" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="101" y="112" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="101" y="134" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="101" y="156" width="7" height="7" rx="1.5" opacity="0.3"></rect>
	</g>
	<g class="col c4" fill="currentColor">
		<rect x="123" y="46" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="123" y="68" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="123" y="90" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="123" y="112" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="123" y="134" width="7" height="7" rx="1.5" opacity="0.25"></rect>
		<rect x="123" y="156" width="7" height="7" rx="1.5" opacity="0.2"></rect>
	</g>
	<g class="col c5" fill="currentColor">
		<rect x="145" y="46" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="145" y="68" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="145" y="90" width="7" height="7" rx="1.5" opacity="0.25"></rect>
		<rect x="145" y="112" width="7" height="7" rx="1.5" opacity="0.35"></rect>
		<rect x="145" y="134" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="145" y="156" width="7" height="7" rx="1.5" opacity="0.15"></rect>
	</g>
	<g class="col c6" fill="currentColor">
		<rect x="167" y="46" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="167" y="68" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="167" y="90" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="167" y="112" width="7" height="7" rx="1.5" opacity="0.25"></rect>
		<rect x="167" y="134" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="167" y="156" width="7" height="7" rx="1.5" opacity="0.35"></rect>
	</g>
	<g class="col c7" fill="currentColor">
		<rect x="189" y="46" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="189" y="68" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="189" y="90" width="7" height="7" rx="1.5" opacity="0.35"></rect>
		<rect x="189" y="112" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="189" y="134" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="189" y="156" width="7" height="7" rx="1.5" opacity="0.2"></rect>
	</g>
	<g class="col c8" fill="currentColor">
		<rect x="211" y="46" width="7" height="7" rx="1.5" opacity="0.15"></rect>
		<rect x="211" y="68" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="211" y="90" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="211" y="112" width="7" height="7" rx="1.5" opacity="0.3"></rect>
		<rect x="211" y="134" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="211" y="156" width="7" height="7" rx="1.5" opacity="0.4"></rect>
	</g>
	<g class="col c9" fill="currentColor">
		<rect x="233" y="46" width="7" height="7" rx="1.5" opacity="0.25"></rect>
		<rect x="233" y="68" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="233" y="90" width="7" height="7" rx="1.5" opacity="0.4"></rect>
		<rect x="233" y="112" width="7" height="7" rx="1.5" opacity="0.2"></rect>
		<rect x="233" y="134" width="7" height="7" rx="1.5" opacity="0.35"></rect>
		<rect x="233" y="156" width="7" height="7" rx="1.5" opacity="0.15"></rect>
	</g>

	<g fill="var(--accent)">
		<rect class="blip b1" x="79" y="68" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b2" x="145" y="46" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b3" x="189" y="112" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b4" x="123" y="134" width="7" height="7" rx="1.5" opacity="0"></rect>
		<rect class="blip b5" x="233" y="90" width="7" height="7" rx="1.5" opacity="0"></rect>
	</g>
</svg>

<style>
	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. At rest the columns sit dimmed; the crest lifts
	   each to full for a beat as it passes. Reduced motion: markup opacity. */
	@media (prefers-reduced-motion: no-preference) {
		.col {
			animation: swv-crest 7s linear infinite;
		}
		.c1 {
			animation-delay: 0.45s;
		}
		.c2 {
			animation-delay: 0.9s;
		}
		.c3 {
			animation-delay: 1.35s;
		}
		.c4 {
			animation-delay: 1.8s;
		}
		.c5 {
			animation-delay: 2.25s;
		}
		.c6 {
			animation-delay: 2.7s;
		}
		.c7 {
			animation-delay: 3.15s;
		}
		.c8 {
			animation-delay: 3.6s;
		}
		.c9 {
			animation-delay: 4.05s;
		}
		/* Each blip rides its own column's crest. */
		.blip {
			animation: swv-blip 7s linear infinite;
		}
		.b1 {
			animation-delay: 0.9s;
		}
		.blip.b2 {
			animation-delay: 2.25s;
		}
		.blip.b3 {
			animation-delay: 3.15s;
		}
		.blip.b4 {
			animation-delay: 1.8s;
		}
		.blip.b5 {
			animation-delay: 4.05s;
		}

		@keyframes swv-crest {
			0%,
			1% {
				opacity: 0.55;
			}
			4% {
				opacity: 1;
			}
			11%,
			100% {
				opacity: 0.55;
			}
		}
		@keyframes swv-blip {
			0%,
			3% {
				opacity: 0;
			}
			6%,
			60% {
				opacity: 1;
			}
			72%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
