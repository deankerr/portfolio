---
// hash buckets — items rain in, the hash bar routes each to its bucket.
// Two collide into the same bucket and it chains: the overflow cell stacks
// on top in accent. Constant-time until it isn't.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the hash bar -->
	<rect
		x="40"
		y="52"
		width="178"
		height="9"
		rx="2"
		stroke="currentColor"
		stroke-width="1"
		fill="var(--surface)"
		opacity="0.6"></rect>
	<g stroke="currentColor" stroke-width="1" opacity="0.35">
		<line x1="85" y1="54" x2="85" y2="59"></line>
		<line x1="129" y1="54" x2="129" y2="59"></line>
		<line x1="173" y1="54" x2="173" y2="59"></line>
	</g>

	<!-- the buckets -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="2 3" opacity="0.35">
		<rect x="60" y="78" width="18" height="50" rx="2"></rect>
		<rect x="105" y="78" width="18" height="50" rx="2"></rect>
		<rect x="150" y="78" width="18" height="50" rx="2"></rect>
		<rect x="195" y="78" width="18" height="50" rx="2"></rect>
	</g>

	<!-- items in flight -->
	<g fill="currentColor">
		<rect class="drop i1" x="-2.5" y="-2.5" width="5" height="5" rx="1" opacity="0"></rect>
		<rect class="drop i2" x="-2.5" y="-2.5" width="5" height="5" rx="1" opacity="0"></rect>
		<rect class="drop i4" x="-2.5" y="-2.5" width="5" height="5" rx="1" opacity="0"></rect>
	</g>
	<rect
		class="drop i3"
		x="-2.5"
		y="-2.5"
		width="5"
		height="5"
		rx="1"
		fill="var(--accent)"
		opacity="0"></rect>

	<!-- landed cells; the chained one is accent -->
	<g fill="currentColor">
		<rect class="cell c1" x="63" y="114" width="12" height="10" rx="1.5" opacity="0"></rect>
		<rect class="cell c2" x="153" y="114" width="12" height="10" rx="1.5" opacity="0"></rect>
		<rect class="cell c4" x="198" y="114" width="12" height="10" rx="1.5" opacity="0"></rect>
	</g>
	<rect
		class="cell c3"
		x="153"
		y="101"
		width="12"
		height="10"
		rx="1.5"
		fill="var(--accent)"
		opacity="0"></rect>
</svg>

<style>
	.i1 {
		offset-path: path('M 80 24 L 80 46 C 80 56 69 56 69 64 L 69 74');
	}
	.i2 {
		offset-path: path('M 150 24 L 150 46 C 150 56 159 56 159 64 L 159 74');
	}
	.i3 {
		offset-path: path('M 128 24 L 128 46 C 128 56 159 56 159 64 L 159 74');
	}
	.i4 {
		offset-path: path('M 188 24 L 188 46 C 188 56 204 56 204 64 L 204 74');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: bar and buckets, empty.
	   7s cycle; items are transient so delays are safe, but landed cells need
	   a shared reset — each gets its own keyframes. */
	@media (prefers-reduced-motion: no-preference) {
		.drop {
			animation: hb-drop 7s linear infinite;
		}
		.i2 {
			animation-delay: 1s;
		}
		.i3 {
			animation-delay: 2.1s;
		}
		.i4 {
			animation-delay: 3.1s;
		}
		.c1 {
			animation: hb-c1 7s linear infinite;
		}
		.c2 {
			animation: hb-c2 7s linear infinite;
		}
		.c3 {
			animation: hb-c3 7s linear infinite;
		}
		.c4 {
			animation: hb-c4 7s linear infinite;
		}

		@keyframes hb-drop {
			0%,
			3% {
				offset-distance: 0%;
				opacity: 0;
			}
			6% {
				opacity: 0.8;
			}
			15% {
				opacity: 0.8;
			}
			18%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes hb-c1 {
			0%,
			17% {
				opacity: 0;
			}
			20%,
			88% {
				opacity: 0.4;
			}
			94%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hb-c2 {
			0%,
			31% {
				opacity: 0;
			}
			34%,
			88% {
				opacity: 0.4;
			}
			94%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hb-c3 {
			0%,
			47% {
				opacity: 0;
			}
			50%,
			88% {
				opacity: 1;
			}
			94%,
			100% {
				opacity: 0;
			}
		}
		@keyframes hb-c4 {
			0%,
			61% {
				opacity: 0;
			}
			64%,
			88% {
				opacity: 0.4;
			}
			94%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
