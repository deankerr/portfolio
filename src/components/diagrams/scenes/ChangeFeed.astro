---
// change feed — pub-sub dispatch. Events stream along the feed line and pass
// a filter gate; most continue through, the matching one deflects down to a
// subscriber, which pulses on delivery. ORCA's monitor → Discord alert path.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the feed -->
	<line
		x1="12"
		y1="56"
		x2="222"
		y2="56"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="3 5"
		opacity="0.3"></line>

	<!-- the filter gate -->
	<line
		class="gate"
		x1="150"
		y1="40"
		x2="150"
		y2="72"
		stroke="currentColor"
		stroke-width="1.25"
		stroke-dasharray="2 3"
		opacity="0.5"></line>

	<!-- the subscription drop -->
	<path
		d="M 150 56 C 168 56 176 72 184 92 L 191 108"
		stroke="var(--accent)"
		stroke-width="1"
		stroke-dasharray="3 5"
		opacity="0.35"></path>
	<circle
		class="sub"
		cx="192"
		cy="112"
		r="4"
		stroke="var(--accent)"
		stroke-width="1.25"
		fill="var(--surface)"></circle>
	<circle class="pulse" cx="192" cy="112" r="8" stroke="var(--accent)" stroke-width="1" opacity="0"
	></circle>

	<!-- pass-through events -->
	<g fill="currentColor">
		<rect class="ev" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		<rect class="ev e2" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		<rect class="ev e3" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		<rect class="ev e4" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
	</g>
	<!-- the match, deflected to its subscriber -->
	<rect class="match" x="-2.5" y="-2.5" width="5" height="5" rx="1" fill="var(--accent)" opacity="0"
	></rect>
</svg>

<style>
	/* Routes live here so the markup stays geometry-only. */
	.ev {
		offset-path: path('M 12 56 L 222 56');
	}
	.match {
		offset-path: path('M 12 56 L 150 56 C 168 56 176 72 184 92 L 191 108');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: feed, gate, and subscriber at rest. */
	@media (prefers-reduced-motion: no-preference) {
		.ev {
			animation: cf-travel 4s linear infinite;
		}
		.e2 {
			animation-delay: 0.9s;
		}
		.e3 {
			animation-delay: 1.7s;
		}
		.e4 {
			animation-delay: 2.9s;
		}
		.match {
			animation: cf-travel 4s linear infinite;
			animation-delay: 2.2s;
		}
		.pulse {
			transform-box: fill-box;
			transform-origin: center;
			animation: cf-pulse 4s linear infinite;
			animation-delay: 2.2s;
		}
		.gate {
			animation: cf-gate 4s linear infinite;
			animation-delay: 2.2s;
		}

		@keyframes cf-travel {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			8% {
				opacity: 0.6;
			}
			92% {
				opacity: 0.6;
			}
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		/* The match crosses the gate at ~66% of its run — the gate winks, and
		   the subscriber rings just as the dot lands (100% → wraps to 0%). */
		@keyframes cf-gate {
			0%,
			60% {
				opacity: 0.5;
			}
			66% {
				opacity: 1;
				stroke: var(--accent);
			}
			74%,
			100% {
				opacity: 0.5;
			}
		}
		/* The match lands at its 100%/0% wrap — the ring blooms right after. */
		@keyframes cf-pulse {
			0% {
				transform: scale(0.45);
				opacity: 0;
			}
			3% {
				opacity: 0.65;
			}
			16%,
			100% {
				transform: scale(1.6);
				opacity: 0;
			}
		}
	}
</style>
