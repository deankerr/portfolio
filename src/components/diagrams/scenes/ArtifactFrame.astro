---
// artifact frame — a fenced code block in the chat becomes a live, sandboxed
// artifact. The source transmits into the frame, the render lights up inside
// the sandbox boundary — and when it throws, the error arcs back to the host
// over postMessage instead of dying silently.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the chat column -->
	<g fill="currentColor">
		<rect x="26" y="34" width="58" height="12" rx="3" opacity="0.15"></rect>
		<rect x="26" y="52" width="46" height="12" rx="3" opacity="0.15"></rect>
	</g>
	<!-- the fenced code block -->
	<rect x="26" y="72" width="58" height="30" rx="3" stroke="currentColor" stroke-width="1" fill="var(--surface)" opacity="0.7"
	></rect>
	<g stroke="currentColor" stroke-width="1.5" opacity="0.4">
		<line x1="33" y1="80" x2="55" y2="80"></line>
		<line x1="33" y1="87" x2="70" y2="87"></line>
		<line x1="33" y1="94" x2="62" y2="94"></line>
	</g>

	<!-- the sandbox boundary -->
	<rect x="120" y="40" width="94" height="66" rx="4" stroke="currentColor" stroke-width="1" stroke-dasharray="3 4" opacity="0.45"
	></rect>

	<!-- transmit: source into the frame -->
	<path
		d="M 86 84 C 102 84 106 76 118 72"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="3 5"
		opacity="0.3"></path>
	<circle class="tx" r="2.5" fill="var(--accent)" opacity="0"></circle>

	<!-- the live render -->
	<g class="render" opacity="0">
		<circle cx="141" cy="62" r="7" stroke="var(--accent)" stroke-width="1.25" fill="var(--surface)"
		></circle>
		<g stroke="currentColor" stroke-width="1.5" opacity="0.5">
			<line x1="156" y1="56" x2="200" y2="56"></line>
			<line x1="156" y1="66" x2="188" y2="66"></line>
		</g>
		<rect x="134" y="80" width="66" height="14" rx="2" stroke="currentColor" stroke-width="1" opacity="0.4"
		></rect>
	</g>

	<!-- the throw, and its postMessage home -->
	<g class="err" stroke="var(--accent)" stroke-width="1.5" opacity="0">
		<line x1="163" y1="83" x2="171" y2="91"></line>
		<line x1="171" y1="83" x2="163" y2="91"></line>
	</g>
	<path
		d="M 118 100 C 104 106 96 108 86 106"
		stroke="var(--accent)"
		stroke-width="1"
		stroke-dasharray="3 5"
		opacity="0.3"></path>
	<circle class="post" r="2.5" fill="var(--accent)" opacity="0"></circle>
	<!-- surfaced on the host -->
	<line class="caught" x1="30" y1="110" x2="44" y2="110" stroke="var(--accent)" stroke-width="2" opacity="0"
	></line>
</svg>

<style>
	.tx {
		offset-path: path('M 86 84 C 102 84 106 76 118 72');
	}
	.post {
		offset-path: path('M 118 100 C 104 106 96 108 86 106');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: chat, code block, empty frame.
	   9s cycle: transmit → render → throw → postMessage back → surfaced. */
	@media (prefers-reduced-motion: no-preference) {
		.tx {
			animation: af-tx 9s linear infinite;
		}
		.render {
			animation: af-render 9s linear infinite;
		}
		.err {
			animation: af-err 9s linear infinite;
		}
		.post {
			animation: af-post 9s linear infinite;
		}
		.caught {
			animation: af-caught 9s linear infinite;
		}

		@keyframes af-tx {
			0%,
			8% {
				offset-distance: 0%;
				opacity: 0;
			}
			11% {
				opacity: 1;
			}
			20% {
				offset-distance: 100%;
				opacity: 1;
			}
			24%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes af-render {
			0%,
			22% {
				opacity: 0;
			}
			30%,
			88% {
				opacity: 1;
			}
			95%,
			100% {
				opacity: 0;
			}
		}
		@keyframes af-err {
			0%,
			46% {
				opacity: 0;
			}
			50%,
			66% {
				opacity: 1;
			}
			70%,
			100% {
				opacity: 0;
			}
		}
		@keyframes af-post {
			0%,
			52% {
				offset-distance: 0%;
				opacity: 0;
			}
			55% {
				opacity: 1;
			}
			64% {
				offset-distance: 100%;
				opacity: 1;
			}
			68%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes af-caught {
			0%,
			64% {
				opacity: 0;
			}
			68%,
			88% {
				opacity: 1;
			}
			95%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
