---
// session grid — the command is the session name. Six deterministic slots;
// one process crashes and its exit stays visible instead of vanishing. The
// same run command arrives again and re-lights the same slot — never a new
// one, nothing to track.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the slots -->
	<g stroke="currentColor" stroke-width="1.25" fill="var(--surface)" opacity="0.7">
		<rect x="36" y="38" width="48" height="26" rx="3"></rect>
		<rect x="156" y="38" width="48" height="26" rx="3"></rect>
		<rect x="36" y="80" width="48" height="26" rx="3"></rect>
		<rect x="96" y="80" width="48" height="26" rx="3"></rect>
		<rect x="156" y="80" width="48" height="26" rx="3"></rect>
	</g>
	<!-- the slot that will crash -->
	<rect
		class="crashbox"
		x="96"
		y="38"
		width="48"
		height="26"
		rx="3"
		stroke="currentColor"
		stroke-width="1.25"
		fill="var(--surface)"
		opacity="0.7"></rect>

	<!-- running indicators -->
	<g stroke="currentColor" stroke-width="2" opacity="0.4">
		<line x1="46" y1="51" x2="58" y2="51"></line>
		<line x1="62" y1="51" x2="68" y2="51"></line>
		<line x1="166" y1="51" x2="180" y2="51"></line>
		<line x1="46" y1="93" x2="60" y2="93"></line>
		<line x1="106" y1="93" x2="116" y2="93"></line>
		<line x1="120" y1="93" x2="130" y2="93"></line>
		<line x1="166" y1="93" x2="174" y2="93"></line>
		<line x1="178" y1="93" x2="188" y2="93"></line>
	</g>
	<g class="alive" stroke="currentColor" stroke-width="2" opacity="0.4">
		<line x1="106" y1="51" x2="118" y2="51"></line>
		<line x1="122" y1="51" x2="132" y2="51"></line>
	</g>

	<!-- the crash: exit status, visible, not vanished -->
	<g class="dead" stroke="var(--accent)" stroke-width="1.5" opacity="0">
		<line x1="115" y1="46" x2="125" y2="56"></line>
		<line x1="125" y1="46" x2="115" y2="56"></line>
	</g>

	<!-- the same `run` again, straight to the same slot -->
	<circle class="rerun" r="2.75" fill="var(--accent)" opacity="0"></circle>
</svg>

<style>
	.rerun {
		offset-path: path('M 14 24 C 50 24 80 30 94 42');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: all six slots running.
	   9s cycle: crash → exit stays visible → rerun arrives → respawn. */
	@media (prefers-reduced-motion: no-preference) {
		.alive {
			animation: sg-alive 9s linear infinite;
		}
		.dead {
			animation: sg-dead 9s linear infinite;
		}
		.crashbox {
			animation: sg-crashbox 9s linear infinite;
		}
		.rerun {
			animation: sg-rerun 9s linear infinite;
		}

		@keyframes sg-alive {
			0%,
			16% {
				opacity: 0.4;
			}
			19%,
			70% {
				opacity: 0;
			}
			74%,
			100% {
				opacity: 0.4;
			}
		}
		/* The exit marker holds for the whole dead window — that's the point. */
		@keyframes sg-dead {
			0%,
			16% {
				opacity: 0;
			}
			19%,
			70% {
				opacity: 1;
			}
			74%,
			100% {
				opacity: 0;
			}
		}
		@keyframes sg-crashbox {
			0%,
			16% {
				opacity: 0.7;
				stroke: currentColor;
			}
			18%,
			22% {
				opacity: 1;
				stroke: var(--accent);
			}
			30%,
			70% {
				opacity: 0.55;
				stroke: currentColor;
			}
			74% {
				opacity: 1;
			}
			80%,
			100% {
				opacity: 0.7;
			}
		}
		@keyframes sg-rerun {
			0%,
			54% {
				offset-distance: 0%;
				opacity: 0;
			}
			58% {
				opacity: 1;
			}
			68% {
				offset-distance: 100%;
				opacity: 1;
			}
			72%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
	}
</style>
