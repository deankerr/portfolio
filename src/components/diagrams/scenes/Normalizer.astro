---
// normalizer — dialects in, typed events out. Three jagged wire dialects flow
// into the library; what leaves is one even, typed pulse train — over the
// faint raw line, which is always there underneath.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- three server dialects, none quite alike -->
	<g class="wire" stroke="currentColor" stroke-width="1" stroke-dasharray="4 3 1 3" opacity="0.5">
		<path d="M 14 48 L 34 42 L 52 52 L 72 44 L 90 56 L 106 64"></path>
		<path d="M 14 72 L 36 68 L 56 76 L 76 70 L 96 73 L 106 72"></path>
		<path d="M 14 96 L 32 102 L 54 90 L 74 100 L 94 88 L 106 80"></path>
	</g>

	<!-- the library -->
	<rect x="108" y="56" width="26" height="32" rx="3" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
	></rect>
	<circle class="core" cx="121" cy="72" r="2" fill="var(--accent)"></circle>

	<!-- the raw line, always underneath -->
	<line x1="134" y1="72" x2="222" y2="72" stroke="currentColor" stroke-width="1" opacity="0.2"></line>

	<!-- one even, typed pulse train -->
	<g fill="var(--accent)">
		<rect class="typed" x="-2.5" y="-2.5" width="5" height="5" rx="1" opacity="0"></rect>
		<rect class="typed t2" x="-2.5" y="-2.5" width="5" height="5" rx="1" opacity="0"></rect>
		<rect class="typed t3" x="-2.5" y="-2.5" width="5" height="5" rx="1" opacity="0"></rect>
	</g>
</svg>

<style>
	.typed {
		offset-path: path('M 136 72 L 220 72');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: wires, library, raw line at rest.
	   The wires churn irregularly; the output is metronomic — that contrast
	   is the whole diagram. */
	@media (prefers-reduced-motion: no-preference) {
		.wire {
			/* Dash period is 11 — a full multiple keeps the loop seamless. */
			animation: nm-wire 1.6s linear infinite;
		}
		.core {
			animation: nm-core 2.4s ease-in-out infinite;
		}
		.typed {
			animation: nm-typed 2.4s linear infinite;
		}
		.t2 {
			animation-delay: 0.8s;
		}
		.t3 {
			animation-delay: 1.6s;
		}

		@keyframes nm-wire {
			to {
				stroke-dashoffset: -11;
			}
		}
		@keyframes nm-core {
			0%,
			100% {
				opacity: 0.5;
			}
			50% {
				opacity: 1;
			}
		}
		@keyframes nm-typed {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			10% {
				opacity: 1;
			}
			88% {
				opacity: 1;
			}
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
	}
</style>
