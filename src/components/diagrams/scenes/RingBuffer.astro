---
// ring buffer — writer and reader chase each other around a fixed ring of
// cells. The accent arc trailing the writer is the unread region; the reader
// rides at its tail. Nothing allocates, nothing stops — pure steady state.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the ring of cells, twelve slots at 30° -->
	<g fill="currentColor" opacity="0.35">
		<rect x="153.5" y="68.5" width="7" height="7" rx="1.5"></rect>
		<rect x="148.1" y="88.5" width="7" height="7" rx="1.5"></rect>
		<rect x="133.5" y="103.1" width="7" height="7" rx="1.5"></rect>
		<rect x="113.5" y="108.5" width="7" height="7" rx="1.5"></rect>
		<rect x="93.5" y="103.1" width="7" height="7" rx="1.5"></rect>
		<rect x="78.9" y="88.5" width="7" height="7" rx="1.5"></rect>
		<rect x="73.5" y="68.5" width="7" height="7" rx="1.5"></rect>
		<rect x="78.9" y="48.5" width="7" height="7" rx="1.5"></rect>
		<rect x="93.5" y="33.9" width="7" height="7" rx="1.5"></rect>
		<rect x="113.5" y="28.5" width="7" height="7" rx="1.5"></rect>
		<rect x="133.5" y="33.9" width="7" height="7" rx="1.5"></rect>
		<rect x="148.1" y="48.5" width="7" height="7" rx="1.5"></rect>
	</g>

	<!-- the unread region: an arc that ends at the writer and starts at the
	     reader, rotating with them. Circumference ≈ 207; the dash is a
	     quarter of it. -->
	<g class="spin">
		<circle
			cx="117"
			cy="72"
			r="33"
			stroke="var(--accent)"
			stroke-width="1.5"
			stroke-dasharray="52 155"
			opacity="0.35"
			transform="rotate(-90 117 72)"></circle>
		<circle cx="150" cy="72" r="2.75" fill="var(--accent)"></circle>
	</g>
	<!-- the reader, a quarter turn behind -->
	<g class="spin chase">
		<circle cx="150" cy="72" r="2.5" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
		></circle>
	</g>

	<circle cx="117" cy="72" r="2" fill="currentColor" opacity="0.3"></circle>
</svg>

<style>
	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: the ring with both cursors parked.
	   Continuous — a ring buffer has no reset. */
	@media (prefers-reduced-motion: no-preference) {
		.spin {
			transform-box: view-box;
			transform-origin: 117px 72px;
			animation: rb-spin 8s linear infinite;
		}
		.chase {
			animation-delay: -6s;
		}

		@keyframes rb-spin {
			to {
				transform: rotate(360deg);
			}
		}
	}
</style>
