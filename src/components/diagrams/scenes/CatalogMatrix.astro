	</g>
	<line
		class="sweep"
		x1="28"
		y1="40"
		x2="28"
		y2="164"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="3 3"
		opacity="0"></line>
</svg>

<style>
	/* Full shorthand, name included — a nameless `animation: 7s …` base rule
	   gets minified to `animation: none`. Static fallback: matrix only. */
	@media (prefers-reduced-motion: no-preference) {
		.sweep {
			animation: cm-sweep 7s linear infinite;
		}
		.blip {
			animation: cm-blip 7s linear infinite;
		}
		.b2 {
			animation-delay: 0.4s;
		}
		.b3 {
			animation-delay: 0.9s;
		}
		.b4 {
			animation-delay: 1.4s;
		}
		.b5 {
			animation-delay: 1.9s;
		}

		@keyframes cm-sweep {
			0% {
				transform: translateX(0);
				opacity: 0;
			}
			5% {
				opacity: 0.5;
			}
			70% {
				opacity: 0.5;
			}
			77%,
			100% {
				transform: translateX(216px);
				opacity: 0;
			}
		}
		@keyframes cm-blip {
			0%,
			24% {
				opacity: 0;
			}
			29%,
			67% {
				opacity: 1;
			}
			80%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
