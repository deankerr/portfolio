---
// sandbox overlay — the seatbelt. A namespace boundary draws itself around
// the sandboxed user's world; the host mounts inside hollow out to empty
// tmpfs. A process probes the wall and bounces — the host dirs outside stay
// solid and untouched.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- host directories, outside the namespace — solid, untouched -->
	<g fill="currentColor">
		<rect x="26" y="58" width="20" height="16" rx="2" opacity="0.35"></rect>
		<rect x="26" y="82" width="20" height="16" rx="2" opacity="0.25"></rect>
	</g>

	<!-- the same mount points, inside — solid until the overlay lands -->
	<g class="mount" fill="currentColor">
		<rect x="108" y="58" width="20" height="16" rx="2" opacity="0.35"></rect>
		<rect x="140" y="58" width="20" height="16" rx="2" opacity="0.25"></rect>
	</g>
	<g class="empty" stroke="currentColor" stroke-width="1" stroke-dasharray="2 3" opacity="0">
		<rect x="108" y="58" width="20" height="16" rx="2"></rect>
		<rect x="140" y="58" width="20" height="16" rx="2"></rect>
	</g>

	<!-- the namespace boundary, drawn on -->
	<rect
		class="wall"
		x="92"
		y="42"
		width="126"
		height="66"
		rx="6"
		stroke="var(--accent)"
		stroke-width="1.25"
		opacity="0.8"></rect>

	<!-- the process: probes the wall, bounces -->
	<circle class="proc" cx="188" cy="92" r="2.75" fill="var(--accent)" opacity="0"></circle>
	<circle class="knock" cx="95" cy="92" r="6" stroke="var(--accent)" stroke-width="1" opacity="0"
	></circle>
</svg>

<style>
	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: boundary drawn, mounts hollow —
	   so hide the solid inside-mounts only when animation will replace them. */
	@media (prefers-reduced-motion: no-preference) {
		.wall {
			/* Perimeter ≈ 384 — drawn on, then held. */
			stroke-dasharray: 384;
			animation: so-wall 8s linear infinite;
		}
		.mount {
			animation: so-mount 8s linear infinite;
		}
		.empty {
			animation: so-empty 8s linear infinite;
		}
		.proc {
			animation: so-proc 8s ease-in-out infinite;
		}
		.knock {
			transform-box: fill-box;
			transform-origin: center;
			animation: so-knock 8s linear infinite;
		}

		@keyframes so-wall {
			0% {
				stroke-dashoffset: 384;
				opacity: 0.8;
			}
			18% {
				stroke-dashoffset: 0;
			}
			92% {
				stroke-dashoffset: 0;
				opacity: 0.8;
			}
			97%,
			100% {
				stroke-dashoffset: 0;
				opacity: 0;
			}
		}
		/* Once the wall closes, the host mounts inside empty out. */
		@keyframes so-mount {
			0%,
			20% {
				opacity: 1;
			}
			32%,
			100% {
				opacity: 0;
			}
		}
		@keyframes so-empty {
			0%,
			22% {
				opacity: 0;
			}
			34%,
			92% {
				opacity: 0.5;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
		/* Patrol left toward the wall, bounce, return. */
		@keyframes so-proc {
			0%,
			36% {
				transform: translateX(0);
				opacity: 0;
			}
			40% {
				opacity: 1;
			}
			56% {
				transform: translateX(-86px);
			}
			76% {
				transform: translateX(0);
				opacity: 1;
			}
			80%,
			100% {
				transform: translateX(0);
				opacity: 0;
			}
		}
		@keyframes so-knock {
			0%,
			54% {
				transform: scale(0.4);
				opacity: 0;
			}
			57% {
				opacity: 0.7;
			}
			66%,
			100% {
				transform: scale(1.5);
				opacity: 0;
			}
		}
	}
</style>
