---
// queue & artifacts — the job is transient plumbing; the artifact is the
// point. A job travels the queue lane, passes through the gate one at a time,
// and lands as an artifact in the library grid — which only ever grows.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the queue lane and the gate -->
	<line
		x1="14"
		y1="60"
		x2="96"
		y2="60"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="3 5"
		opacity="0.35"></line>
	<circle cx="106" cy="60" r="6" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
	></circle>
	<circle class="gatep" cx="106" cy="60" r="10" stroke="var(--accent)" stroke-width="1" opacity="0"
	></circle>

	<!-- the drop into the library -->
	<path
		d="M 114 62 C 138 68 148 74 156 78"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="3 5"
		opacity="0.3"></path>

	<!-- the library — everything kept, provenance attached -->
	<g fill="currentColor">
		<rect x="152" y="82" width="13" height="13" rx="2" opacity="0.3"></rect>
		<rect x="170" y="82" width="13" height="13" rx="2" opacity="0.2"></rect>
		<rect x="188" y="82" width="13" height="13" rx="2" opacity="0.35"></rect>
		<rect x="152" y="100" width="13" height="13" rx="2" opacity="0.25"></rect>
		<rect x="170" y="100" width="13" height="13" rx="2" opacity="0.35"></rect>
		<rect x="188" y="100" width="13" height="13" rx="2" opacity="0.2"></rect>
		<rect x="152" y="118" width="13" height="13" rx="2" opacity="0.35"></rect>
		<rect x="170" y="118" width="13" height="13" rx="2" opacity="0.25"></rect>
	</g>
	<!-- the next slot -->
	<rect
		x="188"
		y="64"
		width="13"
		height="13"
		rx="2"
		stroke="currentColor"
		stroke-width="1"
		stroke-dasharray="2 3"
		opacity="0.35"></rect>
	<rect class="landed" x="188" y="64" width="13" height="13" rx="2" fill="var(--accent)" opacity="0"
	></rect>

	<!-- the job in flight, and its artifact after the gate -->
	<rect class="job" x="-2.5" y="-2.5" width="5" height="5" rx="1" fill="var(--accent)" opacity="0"
	></rect>
	<circle class="out" r="2.75" fill="var(--accent)" opacity="0"></circle>
</svg>

<style>
	.job {
		offset-path: path('M 14 60 L 100 60');
	}
	.out {
		offset-path: path('M 112 60 C 140 62 168 62 194 68');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: gate and library at rest.
	   5s cycle: job → gate → artifact lands → the library keeps it. */
	@media (prefers-reduced-motion: no-preference) {
		.job {
			animation: qw-job 5s linear infinite;
		}
		.gatep {
			transform-box: fill-box;
			transform-origin: center;
			animation: qw-gate 5s linear infinite;
		}
		.out {
			animation: qw-out 5s linear infinite;
		}
		.landed {
			animation: qw-land 5s linear infinite;
		}

		@keyframes qw-job {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			5% {
				opacity: 1;
			}
			34% {
				opacity: 1;
			}
			38%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes qw-gate {
			0%,
			36% {
				transform: scale(0.5);
				opacity: 0;
			}
			40% {
				opacity: 0.7;
			}
			54%,
			100% {
				transform: scale(1.4);
				opacity: 0;
			}
		}
		@keyframes qw-out {
			0%,
			42% {
				offset-distance: 0%;
				opacity: 0;
			}
			46% {
				opacity: 1;
			}
			66% {
				opacity: 1;
			}
			70%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes qw-land {
			0%,
			68% {
				opacity: 0;
			}
			72%,
			90% {
				opacity: 1;
			}
			97%,
			100% {
				opacity: 0;
			}
		}
	}
</style>
