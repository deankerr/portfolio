---
// scene 2 · multiplex bundle — many streams through one connection. Five lanes
// pinch through a single node and cross over to swapped destinations; a token
// rides the accent path end to end. Self-looping (dash flow 1.4s, token 3.6s).
---

<svg
	viewBox="23 34 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<g class="flow" stroke="currentColor" stroke-width="1.25" stroke-dasharray="3 6" opacity="0.55">
		<path d="M 28 79 C 95 79 105 110 140 110 C 175 110 185 141 252 141"></path>
		<path d="M 28 110 C 100 110 180 110 252 110"></path>
		<path d="M 28 141 C 95 141 105 110 140 110 C 175 110 185 79 252 79"></path>
		<path d="M 28 172 C 95 172 105 110 140 110 C 175 110 185 48 252 48"></path>
	</g>
	<path
		class="flow"
		d="M 28 48 C 95 48 105 110 140 110 C 175 110 185 172 252 172"
		stroke="var(--accent)"
		stroke-width="1.5"
		stroke-dasharray="3 6"
		opacity="0.9"></path>
	<circle cx="140" cy="110" r="5" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"
	></circle>
	<g stroke="currentColor" stroke-width="1" fill="var(--surface)" opacity="0.7">
		<circle cx="28" cy="79" r="2.5"></circle>
		<circle cx="28" cy="110" r="2.5"></circle>
		<circle cx="28" cy="141" r="2.5"></circle>
		<circle cx="28" cy="172" r="2.5"></circle>
		<circle cx="252" cy="79" r="2.5"></circle>
		<circle cx="252" cy="110" r="2.5"></circle>
		<circle cx="252" cy="141" r="2.5"></circle>
		<circle cx="252" cy="48" r="2.5"></circle>
	</g>
	<circle cx="28" cy="48" r="2.5" stroke="var(--accent)" stroke-width="1" fill="var(--surface)"
	></circle>
	<circle cx="252" cy="172" r="2.5" stroke="var(--accent)" stroke-width="1" fill="var(--surface)"
	></circle>
	<circle class="travel" r="2.75" fill="var(--accent)" opacity="0"></circle>
</svg>

<style>
	/* The token's route lives here so the markup stays geometry-only. */
	.travel {
		offset-path: path('M 28 48 C 95 48 105 110 140 110 C 175 110 185 172 252 172');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: the bundle at rest. */
	@media (prefers-reduced-motion: no-preference) {
		.flow {
			/* One dash period is 9 — a full multiple keeps the loop seamless. */
			animation: mb-flow 1.4s linear infinite;
		}
		.travel {
			animation: mb-travel 3.6s linear infinite;
		}

		@keyframes mb-flow {
			to {
				stroke-dashoffset: -9;
			}
		}
		@keyframes mb-travel {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			10% {
				opacity: 1;
			}
			90% {
				opacity: 1;
			}
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
	}
</style>
