---
// message tree — the session as a tree, not a transcript. The trunk forks at
// a regeneration point; each branch is a complete history. The active branch
// highlights and a cursor walks it root-to-leaf, then the other takes over —
// branching, regeneration, and editing as derived views.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- the tree -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="3 5" opacity="0.4">
		<line x1="22" y1="72" x2="90" y2="72"></line>
		<line x1="90" y1="72" x2="126" y2="48"></line>
		<line x1="126" y1="48" x2="198" y2="48"></line>
		<line x1="90" y1="72" x2="126" y2="96"></line>
		<line x1="126" y1="96" x2="198" y2="96"></line>
	</g>

	<!-- active-branch highlights -->
	<g fill="none" stroke="var(--accent)" stroke-width="1.25">
		<polyline class="hl a" points="22,72 90,72 126,48 198,48" opacity="0"></polyline>
		<polyline class="hl b" points="22,72 90,72 126,96 198,96" opacity="0"></polyline>
	</g>

	<!-- messages -->
	<g stroke="currentColor" stroke-width="1.25" fill="var(--surface)" opacity="0.6">
		<circle cx="56" cy="72" r="3.5"></circle>
		<circle cx="126" cy="48" r="3.5"></circle>
		<circle cx="162" cy="48" r="3.5"></circle>
		<circle cx="198" cy="48" r="3.5"></circle>
		<circle cx="126" cy="96" r="3.5"></circle>
		<circle cx="162" cy="96" r="3.5"></circle>
		<circle cx="198" cy="96" r="3.5"></circle>
	</g>
	<!-- root and the fork -->
	<circle cx="22" cy="72" r="4" stroke="var(--accent)" stroke-width="1.25" fill="var(--surface)"></circle>
	<circle cx="90" cy="72" r="4.5" stroke="currentColor" stroke-width="1.25" fill="var(--surface)"></circle>

	<!-- the reader's cursor, walking whichever branch is active -->
	<circle class="cur a" r="2.75" fill="var(--accent)" opacity="0"></circle>
	<circle class="cur b" r="2.75" fill="var(--accent)" opacity="0"></circle>
</svg>

<style>
	.cur.a {
		offset-path: path('M 22 72 L 90 72 L 126 48 L 198 48');
	}
	.cur.b {
		offset-path: path('M 22 72 L 90 72 L 126 96 L 198 96');
	}

	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: the tree at rest.
	   9s cycle, two halves: branch A active, then branch B. */
	@media (prefers-reduced-motion: no-preference) {
		.hl.a {
			animation: mt-hla 9s linear infinite;
		}
		.hl.b {
			animation: mt-hlb 9s linear infinite;
		}
		.cur.a {
			animation: mt-cura 9s linear infinite;
		}
		.cur.b {
			animation: mt-curb 9s linear infinite;
		}

		@keyframes mt-hla {
			0%,
			42% {
				opacity: 0.55;
			}
			48%,
			94% {
				opacity: 0;
			}
			100% {
				opacity: 0.55;
			}
		}
		@keyframes mt-hlb {
			0%,
			42% {
				opacity: 0;
			}
			48%,
			94% {
				opacity: 0.55;
			}
			100% {
				opacity: 0;
			}
		}
		@keyframes mt-cura {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			3% {
				opacity: 1;
			}
			36% {
				opacity: 1;
			}
			40%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
		@keyframes mt-curb {
			0%,
			50% {
				offset-distance: 0%;
				opacity: 0;
			}
			53% {
				opacity: 1;
			}
			86% {
				opacity: 1;
			}
			90%,
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
	}
</style>
