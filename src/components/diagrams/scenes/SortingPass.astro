---
// sorting pass — the grid orders itself. A pass sweeps the unsorted bars and
// leaves them sorted in its wake: two bar sets, unsorted and sorted, swapped
// by a pair of complementary clip reveals riding the same sweep line. The
// accent bar is one value you can watch find its place.
---

<svg
	viewBox="0 0 234 143"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<g class="stage">
		<!-- baseline -->
		<line x1="24" y1="112" x2="212" y2="112" stroke="currentColor" stroke-width="1" opacity="0.25"
		></line>

		<!-- unsorted, hidden left-to-right as the pass consumes it -->
		<g class="unsorted">
			<g fill="currentColor" opacity="0.35">
				<rect x="30" y="88" width="7" height="22" rx="1.5"></rect>
				<rect x="43" y="62" width="7" height="48" rx="1.5"></rect>
				<rect x="56" y="100" width="7" height="10" rx="1.5"></rect>
				<rect x="69" y="52" width="7" height="58" rx="1.5"></rect>
				<rect x="82" y="80" width="7" height="30" rx="1.5"></rect>
				<rect x="108" y="94" width="7" height="16" rx="1.5"></rect>
				<rect x="121" y="70" width="7" height="40" rx="1.5"></rect>
				<rect x="134" y="56" width="7" height="54" rx="1.5"></rect>
				<rect x="147" y="86" width="7" height="24" rx="1.5"></rect>
				<rect x="160" y="48" width="7" height="62" rx="1.5"></rect>
				<rect x="173" y="74" width="7" height="36" rx="1.5"></rect>
				<rect x="186" y="98" width="7" height="12" rx="1.5"></rect>
				<rect x="199" y="66" width="7" height="44" rx="1.5"></rect>
			</g>
			<rect x="95" y="44" width="7" height="66" rx="1.5" fill="var(--accent)" opacity="0.9"></rect>
		</g>

		<!-- sorted, revealed left-to-right behind the pass -->
		<g class="sorted">
			<g fill="currentColor" opacity="0.35">
				<rect x="30" y="100" width="7" height="10" rx="1.5"></rect>
				<rect x="43" y="98" width="7" height="12" rx="1.5"></rect>
				<rect x="56" y="94" width="7" height="16" rx="1.5"></rect>
				<rect x="69" y="88" width="7" height="22" rx="1.5"></rect>
				<rect x="82" y="86" width="7" height="24" rx="1.5"></rect>
				<rect x="95" y="80" width="7" height="30" rx="1.5"></rect>
				<rect x="108" y="74" width="7" height="36" rx="1.5"></rect>
				<rect x="121" y="70" width="7" height="40" rx="1.5"></rect>
				<rect x="134" y="66" width="7" height="44" rx="1.5"></rect>
				<rect x="147" y="62" width="7" height="48" rx="1.5"></rect>
				<rect x="160" y="56" width="7" height="54" rx="1.5"></rect>
				<rect x="173" y="52" width="7" height="58" rx="1.5"></rect>
				<rect x="186" y="48" width="7" height="62" rx="1.5"></rect>
			</g>
			<rect x="199" y="44" width="7" height="66" rx="1.5" fill="var(--accent)" opacity="0.9"></rect>
		</g>

		<!-- the pass -->
		<line
			class="pass"
			x1="26"
			y1="40"
			x2="26"
			y2="116"
			stroke="currentColor"
			stroke-width="1"
			stroke-dasharray="3 3"
			opacity="0"></line>
	</g>
</svg>

<style>
	/* Full shorthand, name included — a nameless base shorthand gets minified
	   to `animation: none`. Static fallback: hide the sorted layer so reduced
	   motion sees the unsorted bars only. */
	.sorted {
		opacity: 0;
	}

	@media (prefers-reduced-motion: no-preference) {
		.sorted {
			opacity: 1;
			animation: sp-sorted 7s linear infinite;
		}
		.unsorted {
			animation: sp-unsorted 7s linear infinite;
		}
		.pass {
			animation: sp-pass 7s linear infinite;
		}
		.stage {
			animation: sp-stage 7s linear infinite;
		}

		/* The two clips ride the same edge: sorted appears exactly where
		   unsorted disappears. Values are user units from each layer's box. */
		@keyframes sp-unsorted {
			0%,
			6% {
				clip-path: inset(-10px 0px -10px 0px);
			}
			62%,
			100% {
				clip-path: inset(-10px 0px -10px 186px);
			}
		}
		@keyframes sp-sorted {
			0%,
			6% {
				clip-path: inset(-10px 186px -10px 0px);
			}
			62%,
			100% {
				clip-path: inset(-10px 0px -10px 0px);
			}
		}
		@keyframes sp-pass {
			0%,
			4% {
				transform: translateX(0);
				opacity: 0;
			}
			8% {
				opacity: 0.5;
			}
			58% {
				opacity: 0.5;
			}
			62%,
			100% {
				transform: translateX(184px);
				opacity: 0;
			}
		}
		@keyframes sp-stage {
			0%,
			88% {
				opacity: 1;
			}
			94%,
			97% {
				opacity: 0;
			}
			100% {
				opacity: 1;
			}
		}
	}
</style>
