---
// durian — the durable agent. One persistent entity at the center; the
// participants around it come and go. Its presence sweeps out as a sonar
// ping — each participant lights as the wavefront reaches it. Independent
// message traffic crosses the channels continuously on an irregular cadence.
// Standard canvas: 240×144, 7s ping loop; packet loops deliberately differ.
---

<svg
	viewBox="0 0 240 144"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- channels — faint, they come and go; the agent doesn't depend on them -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="2 4" opacity="0.25">
		<line x1="110" y1="68" x2="40" y2="40"></line>
		<line x1="130" y1="68" x2="200" y2="45"></line>
		<line x1="112" y1="78" x2="52" y2="111"></line>
		<line x1="129" y1="77" x2="194" y2="105"></line>
	</g>

	<!-- the participants -->
	<g stroke="currentColor" stroke-width="1.25" fill="var(--surface)" opacity="0.7">
		<circle cx="36" cy="38" r="4"></circle>
		<circle cx="204" cy="42" r="4"></circle>
		<circle cx="48" cy="114" r="4"></circle>
		<circle cx="198" cy="108" r="4"></circle>
	</g>
	<!-- they light as the elliptical ping reaches them -->
	<g stroke="var(--accent)" stroke-width="1" fill="none">
		<circle class="heard near" cx="204" cy="42" r="7" opacity="0"></circle>
		<circle class="heard near" cx="198" cy="108" r="7" opacity="0"></circle>
		<circle class="heard far" cx="36" cy="38" r="7" opacity="0"></circle>
		<circle class="heard far" cx="48" cy="114" r="7" opacity="0"></circle>
	</g>

	<!-- The wide wavefront matches the canvas, reaching every participant
	     without escaping through the shorter vertical axis first. -->
	<ellipse
		class="ping"
		cx="120"
		cy="72"
		rx="10"
		ry="5"
		stroke="var(--accent)"
		stroke-width="1"
		vector-effect="non-scaling-stroke"
		opacity="0"></ellipse>

	<!-- independent messages travel home on the same faint channels -->
	<g fill="var(--accent)">
		<rect class="packet p1" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		<rect class="packet p2" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		<rect class="packet p3" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
		<rect class="packet p4" x="-2" y="-2" width="4" height="4" rx="1" opacity="0"></rect>
	</g>

	<!-- the durable agent — identity that outlives every session -->
	<circle cx="120" cy="72" r="10" stroke="currentColor" stroke-width="1" opacity="0.3"></circle>
	<circle cx="120" cy="72" r="6" stroke="var(--accent)" stroke-width="1.25" fill="var(--surface)"
	></circle>
	<circle class="core" cx="120" cy="72" r="2.5" fill="var(--accent)"></circle>
</svg>

<style>
	.p1 {
		offset-path: path('M 40 40 L 110 68');
	}
	.p2 {
		offset-path: path('M 200 45 L 130 68');
	}
	.p3 {
		offset-path: path('M 52 111 L 112 78');
	}
	.p4 {
		offset-path: path('M 194 105 L 129 77');
	}

	/* Full shorthand, name included — a nameless base rule gets minified to
	   `animation: none`. Static fallback: agent and participants at rest.
	   The 7s ping and four incommensurate packet loops stay intentionally
	   unsynchronised, so traffic reads as ambient rather than as a reply. */
	@media (prefers-reduced-motion: no-preference) {
		.ping {
			transform-box: fill-box;
			transform-origin: center;
			animation: dur-ping 7s linear infinite;
		}
		.heard.near {
			animation: dur-near 7s linear infinite;
		}
		.heard.far {
			animation: dur-far 7s linear infinite;
		}
		.packet {
			animation: dur-packet 3.8s linear infinite -0.7s;
		}
		.p2 {
			animation-duration: 5.1s;
			animation-delay: -3.4s;
		}
		.p3 {
			animation-duration: 4.4s;
			animation-delay: -1.9s;
		}
		.p4 {
			animation-duration: 6.2s;
			animation-delay: -4.8s;
		}

		@keyframes dur-ping {
			0% {
				transform: scale(0.3);
				opacity: 0;
			}
			6% {
				opacity: 0.6;
			}
			36% {
				opacity: 0.4;
			}
			48%,
			100% {
				transform: scale(11.2);
				opacity: 0;
			}
		}
		@keyframes dur-near {
			0%,
			36% {
				opacity: 0;
			}
			40% {
				opacity: 0.8;
			}
			52%,
			100% {
				opacity: 0;
			}
		}
		@keyframes dur-far {
			0%,
			39% {
				opacity: 0;
			}
			43% {
				opacity: 0.8;
			}
			55%,
			100% {
				opacity: 0;
			}
		}
		@keyframes dur-packet {
			0% {
				offset-distance: 0%;
				opacity: 0;
			}
			9% {
				opacity: 0.9;
			}
			86% {
				offset-distance: 100%;
				opacity: 0.9;
			}
			100% {
				offset-distance: 100%;
				opacity: 0;
			}
		}
	}
</style>
