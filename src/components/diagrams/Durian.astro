---
// durian — the durable agent. One persistent entity at the center; the
// participants around it come and go. Its presence sweeps out as a sonar
// ping — each participant lights as the wavefront reaches it — and a softer
// wave returns, converging on the agent, which registers the receipt.
// Standard canvas: 240×144, 6s master loop.
---

<svg
	viewBox="0 0 240 144"
	fill="none"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
	class="w-full"
>
	<!-- channels — faint, they come and go; the agent doesn't depend on them -->
	<g stroke="currentColor" stroke-width="1" stroke-dasharray="2 4" opacity="0.25">
		<line x1="110" y1="68" x2="40" y2="40"></line>
		<line x1="130" y1="68" x2="200" y2="45"></line>
		<line x1="112" y1="78" x2="52" y2="111"></line>
		<line x1="129" y1="77" x2="194" y2="105"></line>
	</g>

	<!-- the participants -->
	<g stroke="currentColor" stroke-width="1.25" fill="var(--surface)" opacity="0.7">
		<circle cx="36" cy="38" r="4"></circle>
		<circle cx="204" cy="42" r="4"></circle>
		<circle cx="48" cy="114" r="4"></circle>
		<circle cx="198" cy="108" r="4"></circle>
	</g>
	<!-- they light as the ping reaches them -->
	<g stroke="var(--accent)" stroke-width="1" fill="none">
		<circle class="heard near" cx="48" cy="114" r="7" opacity="0"></circle>
		<circle class="heard near" cx="198" cy="108" r="7" opacity="0"></circle>
		<circle class="heard far" cx="204" cy="42" r="7" opacity="0"></circle>
		<circle class="heard far" cx="36" cy="38" r="7" opacity="0"></circle>
	</g>

	<!-- the ping, and the quieter wave coming home -->
	<circle
		class="ping"
		cx="120"
		cy="72"
		r="10"
		stroke="var(--accent)"
		stroke-width="1"
		vector-effect="non-scaling-stroke"
		opacity="0"></circle>
	<circle
		class="echo"
		cx="120"
		cy="72"
		r="10"
		stroke="currentColor"
		stroke-width="1"
		vector-effect="non-scaling-stroke"
		opacity="0"></circle>

	<!-- the durable agent — identity that outlives every session -->
	<circle cx="120" cy="72" r="10" stroke="currentColor" stroke-width="1" opacity="0.3"></circle>
	<circle cx="120" cy="72" r="6" stroke="var(--accent)" stroke-width="1.25" fill="var(--surface)"
	></circle>
	<circle class="core" cx="120" cy="72" r="2.5" fill="var(--accent)"></circle>
</svg>

<style>
	/* Full shorthand, name included — a nameless base rule gets minified to
	   `animation: none`. Static fallback: agent and participants at rest.
	   6s master: ping out → participants light → soft echo home → receipt. */
	@media (prefers-reduced-motion: no-preference) {
		.ping {
			transform-box: fill-box;
			transform-origin: center;
			animation: dur-ping 6s linear infinite;
		}
		.echo {
			transform-box: fill-box;
			transform-origin: center;
			animation: dur-echo 6s linear infinite;
		}
		.heard.near {
			animation: dur-near 6s linear infinite;
		}
		.heard.far {
			animation: dur-far 6s linear infinite;
		}
		.core {
			transform-box: fill-box;
			transform-origin: center;
			animation: dur-core 6s linear infinite;
		}

		@keyframes dur-ping {
			0% {
				transform: scale(0.3);
				opacity: 0;
			}
			6% {
				opacity: 0.6;
			}
			34% {
				opacity: 0.4;
			}
			46%,
			100% {
				transform: scale(10.5);
				opacity: 0;
			}
		}
		/* the reply converges — quieter, in the structure color */
		@keyframes dur-echo {
			0%,
			52% {
				transform: scale(9);
				opacity: 0;
			}
			58% {
				opacity: 0.3;
			}
			84% {
				opacity: 0.25;
			}
			90%,
			100% {
				transform: scale(0.4);
				opacity: 0;
			}
		}
		@keyframes dur-near {
			0%,
			33% {
				opacity: 0;
			}
			36% {
				opacity: 0.8;
			}
			46%,
			100% {
				opacity: 0;
			}
		}
		@keyframes dur-far {
			0%,
			36% {
				opacity: 0;
			}
			39% {
				opacity: 0.8;
			}
			49%,
			100% {
				opacity: 0;
			}
		}
		/* the receipt — the identity registers what came back */
		@keyframes dur-core {
			0%,
			86% {
				transform: scale(1);
			}
			91% {
				transform: scale(1.5);
			}
			96%,
			100% {
				transform: scale(1);
			}
		}
	}
</style>
