---
import type { ContactDetails } from '../../types/portfolio';

interface Props {
	contact: ContactDetails;
}

const { contact } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<header
	class="flex items-center justify-between gap-x-6 gap-y-3 py-2.5 max-[42rem]:flex-col max-[42rem]:items-start"
>
	<div class="flex items-baseline gap-3.5">
		<a class="font-semibold whitespace-nowrap lowercase no-underline" href="#top">dean kerr</a>
		<span class="font-mono text-xs whitespace-nowrap text-ink-faint max-[42rem]:hidden"
			>melbourne, au</span
		>
	</div>
	<nav
		class="flex items-center gap-1 max-[42rem]:w-full max-[42rem]:justify-between"
		aria-label="Contact links"
	>
		<a
			class="inline-flex min-h-11 items-center px-1.5 font-mono text-sm lowercase no-underline hover:underline"
			href={contact.github}
			{...externalLink}>github</a
		>
		<button
			class="inline-flex min-h-11 cursor-pointer items-center px-1.5 font-mono text-sm lowercase hover:underline"
			data-copy={contact.discord}
			title={`copy discord handle: ${contact.discord}`}
		>
			discord
		</button>
		<a
			class="inline-flex min-h-11 items-center px-1.5 font-mono text-sm lowercase no-underline hover:underline"
			href={`mailto:${contact.email}`}>email</a
		>
		<button
			data-theme-toggle
			aria-label="Toggle color theme"
			class="inline-flex min-h-11 cursor-pointer items-center px-1.5 font-mono text-sm lowercase text-ink-faint transition-colors duration-150 ease-out hover:text-ink"
		>
			<span class="dark:hidden">dark</span>
			<span class="hidden dark:inline">light</span>
		</button>
	</nav>
</header>
