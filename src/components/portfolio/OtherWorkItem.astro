---
import type { Project } from '../../types/portfolio';
import Prose from './Prose.astro';

interface Props {
	project: Project;
}

const { project } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
const hasDiagram = Astro.slots.has('diagram');
---

<article class="grid gap-x-10 gap-y-6 border-b border-line py-8 last:border-b-0">
	<div class="summary md:sticky md:top-10 md:self-start">
		<h3 class="font-mono text-base font-bold">{project.name}</h3>
		<p class="mt-2 text-sm leading-tight text-ink-soft">{project.kicker}</p>
		<p class="mt-1.5 font-mono text-xs text-ink-faint">{project.date}</p>
		<a class="mt-3 inline-block font-mono text-xs" href={project.repo} {...externalLink}>github ↗</a
		>
	</div>

	<div class="max-w-[68ch]">
		<div class="text-base">
			<Prose><slot /></Prose>
		</div>
		<div class="mt-7 max-w-[58ch]">
			<div>
				<p class="font-mono text-xs font-medium tracking-widest text-ink-faint lowercase">stack</p>
				<ul class="mt-3 grid gap-2">
					{
						project.stack.map((item) => (
							<li class="text-sm leading-normal text-ink-soft">
								<strong class="font-mono text-xs font-semibold text-ink">{item.name}</strong>
								{item.note && <>: {item.note}</>}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>

	{
		hasDiagram && (
			<div
				class="mx-auto w-full max-w-md text-diagram md:col-start-2 lg:sticky lg:top-10 lg:col-auto lg:max-w-none lg:self-start"
				aria-hidden="true"
			>
				<slot name="diagram" />
			</div>
		)
	}
</article>

<style>
	@media (min-width: 48rem) {
		article {
			grid-template-columns: 12rem minmax(0, 1fr);
		}
	}

	@media (min-width: 64rem) {
		article {
			grid-template-columns: 11rem minmax(0, 1.5fr) minmax(0, 1fr);
		}
	}
</style>
