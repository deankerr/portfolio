---
interface Props {
	tone?: 'page' | 'panel';
}

const { tone = 'page' } = Astro.props;
---

<div
	class:list={['prose text-base', tone === 'panel' ? 'panel text-panel-ink/70' : 'text-ink-soft']}
>
	<slot />
</div>

<style>
	.prose {
		--prose-strong: var(--ink);
	}

	.prose.panel {
		--prose-strong: var(--panel-ink);
	}

	.prose :global(p) {
		max-width: 58ch;
	}

	.prose :global(p + p) {
		margin-top: 0.9em;
	}

	.prose :global(strong) {
		color: var(--prose-strong);
		font-weight: var(--font-weight-semibold);
	}

	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
	}
</style>
