---
import type { ContactDetails } from '../../types/portfolio';

interface Props {
	contact: ContactDetails;
}

const { contact } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<footer
	class="mt-16 flex flex-wrap items-baseline justify-between gap-4 border-t border-line py-5 font-mono text-xs text-ink-faint"
>
	<span>dean kerr</span>
	<nav class="flex flex-wrap items-center gap-x-3 gap-y-1" aria-label="Contact links">
		<a
			class="inline-flex min-h-11 items-center no-underline hover:underline"
			href={contact.github}
			{...externalLink}>github</a
		>
		<button
			class="inline-flex min-h-11 cursor-pointer items-center whitespace-nowrap hover:underline"
			data-copy={contact.discord}
			title="copy discord handle"
		>
			discord · {contact.discord}
		</button>
		<a
			class="inline-flex min-h-11 items-center whitespace-nowrap no-underline hover:underline"
			href={`mailto:${contact.email}`}>{contact.email}</a
		>
	</nav>
</footer>
