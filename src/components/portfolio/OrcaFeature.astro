---
import type { Project, ProjectScreenshot } from '../../types/portfolio';
import Prose from './Prose.astro';
import Screenshot from './Screenshot.astro';

interface Props {
	project: Project;
	screenshots: {
		hero: ProjectScreenshot;
		supporting: ProjectScreenshot[];
	};
}

const { project, screenshots } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<section class="border-t border-line pt-7 pb-14" aria-labelledby="orca-title">
	<article class="rounded-lg bg-panel p-6 text-panel-ink md:p-8 lg:p-11">
		<div class="layout grid gap-x-11 gap-y-9">
			<div>
				<p
					class="eyebrow font-mono text-xs font-medium tracking-widest text-panel-ink/60 uppercase"
				>
					{project.kicker}
				</p>
				<h2
					id="orca-title"
					class="mt-4 text-5xl leading-none font-medium tracking-tight md:text-6xl lg:text-7xl"
				>
					{project.name}
				</h2>
				<p class="mt-3 font-mono text-xs text-panel-ink/60">{project.date}</p>
				<div class="mt-6">
					<Prose tone="panel">
						<slot />
					</Prose>
				</div>
				<div class="mt-7 flex flex-wrap items-baseline gap-x-7 gap-y-2 font-mono text-sm">
					{
						project.live && (
							<a href={project.live} {...externalLink}>
								{new URL(project.live).host} ↗
							</a>
						)
					}
					<a href={project.repo} {...externalLink}>github ↗</a>
				</div>
			</div>

			<div>
				<div class="mx-auto grid w-full max-w-2xl content-start gap-4 lg:sticky lg:top-10 lg:ml-0">
					<figure class="overflow-hidden rounded-md">
						<Screenshot screenshot={screenshots.hero} gallery="orca" width={672} />
					</figure>
					<div class="grid items-start gap-4 sm:grid-cols-2">
						{
							screenshots.supporting.map((screenshot) => (
								<figure class="overflow-hidden rounded-md">
									<Screenshot screenshot={screenshot} gallery="orca" width={328} />
								</figure>
							))
						}
					</div>
				</div>
			</div>
		</div>

		<div class="mt-9 border-t border-panel-line pt-5">
			<div>
				<p class="font-mono text-xs font-medium tracking-widest text-panel-ink/60 lowercase">
					stack
				</p>
				<ul class="mt-4 grid gap-x-9 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
					{
						project.stack.map((item) => (
							<li class="text-sm leading-normal text-panel-ink/70">
								<strong class="font-mono text-xs font-semibold text-panel-ink">{item.name}</strong>
								{item.note && <>: {item.note}</>}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</article>
</section>

<style>
	@media (min-width: 64rem) {
		.layout {
			grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
		}
	}
</style>
