---
import type { Project, ProjectScreenshot } from '../../types/portfolio';
import Prose from './Prose.astro';
import Screenshot from './Screenshot.astro';

interface Props {
	project: Project;
	screenshots: ProjectScreenshot[];
	reverse?: boolean;
}

const { project, screenshots, reverse = false } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<article
	class:list={[
		'feature grid gap-x-11 gap-y-9 border-t border-line py-9 lg:px-8 xl:px-11',
		reverse && 'reverse',
	]}
>
	<div class:list={[reverse && 'xl:order-2']}>
		<div class="xl:sticky xl:top-10">
			<h3
				class="text-3xl leading-none font-medium tracking-tight text-balance md:text-4xl lg:text-5xl"
			>
				{project.name}
			</h3>
			<p class="mt-2.5 text-base text-accent">{project.kicker}</p>
			<p class="mt-1.5 font-mono text-xs text-ink-faint">{project.date}</p>
			<div class="mt-5">
				<Prose><slot /></Prose>
			</div>
			<a class="mt-6 inline-block font-mono text-sm" href={project.repo} {...externalLink}
				>github ↗</a
			>
		</div>
	</div>

	<div class:list={[reverse && 'xl:order-1']}>
		<div
			class:list={[
				'mx-auto grid w-full max-w-[40rem] content-start gap-4',
				reverse ? 'xl:mr-0 xl:ml-auto' : 'xl:ml-0',
			]}
		>
			{
				screenshots.map((screenshot) => (
					<div class="rounded-2xl bg-panel p-3 shadow-frame">
						<figure class="overflow-hidden rounded">
							<Screenshot screenshot={screenshot} gallery={project.name} width={640} />
						</figure>
					</div>
				))
			}
		</div>
	</div>

	<div class:list={['border-t border-line pt-5 xl:col-span-full', reverse && 'xl:order-3']}>
		<div>
			<p class="font-mono text-xs font-medium tracking-widest text-ink-faint lowercase">stack</p>
			<ul class="mt-4 grid gap-x-9 gap-y-3 sm:grid-cols-2 lg:grid-cols-3">
				{
					project.stack.map((item) => (
						<li class="text-sm leading-normal text-ink-soft">
							<strong class="font-mono text-xs font-semibold text-ink">{item.name}</strong>
							{item.note && <>: {item.note}</>}
						</li>
					))
				}
			</ul>
		</div>
	</div>
</article>

<style>
	@media (min-width: 80rem) {
		.feature {
			grid-template-columns: minmax(30rem, 34rem) minmax(0, 1fr);
		}

		.reverse {
			grid-template-columns: minmax(0, 1fr) minmax(30rem, 34rem);
		}
	}
</style>
