---
import { Image } from 'astro:assets';
import type { Project, ProjectScreenshot } from '../../types/portfolio';
import ProjectStack from './ProjectStack.astro';
import Prose from './Prose.astro';

interface Props {
	project: Project;
	screenshots: ProjectScreenshot[];
	reverse?: boolean;
}

const { project, screenshots, reverse = false } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<article class:list={['feature', reverse && 'reverse']}>
	<div class="copy-column">
		<div class="copy">
			<h3>{project.name}</h3>
			<p class="kicker">{project.kicker}</p>
			<p class="date">{project.date}</p>
			<div class="description">
				<Prose><slot /></Prose>
			</div>
			<a class="project-link" href={project.repo} {...externalLink}>github ↗</a>
		</div>
	</div>

	<div class="gallery-column">
		<div class="gallery">
			{
				screenshots.map((screenshot) => (
					<div class="frame">
						<figure>
							<a href={screenshot.src.src} class="glightbox" data-gallery={project.name}>
								<Image
									src={screenshot.src}
									alt={screenshot.alt}
									widths={[480, 720, 960, 1440]}
									sizes="min(40rem, 92vw)"
									loading="lazy"
									quality={90}
									class="screenshot"
								/>
							</a>
						</figure>
					</div>
				))
			}
		</div>
	</div>

	<div class="stack">
		<ProjectStack items={project.stack} layout="wide" />
	</div>
</article>

<style>
	.feature {
		display: grid;
		gap: 2.25rem 2.75rem;
		padding-block: 2.25rem;
		border-top: 1px solid var(--line);
	}

	h3 {
		font-size: 2.1rem;
		font-weight: 500;
		letter-spacing: -0.02em;
		line-height: 0.95;
	}

	.kicker {
		margin-top: 0.625rem;
		color: var(--accent);
		font-size: 0.98rem;
	}

	.date {
		margin-top: 0.375rem;
		color: var(--ink-faint);
		font-family: var(--font-mono);
		font-size: 0.72rem;
	}

	.description {
		margin-top: 1.25rem;
	}

	.project-link {
		display: inline-block;
		margin-top: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}

	.gallery {
		display: grid;
		align-content: start;
		gap: 1rem;
		width: 100%;
		max-width: 40rem;
		margin-inline: auto;
	}

	.frame {
		padding: 0.75rem;
		border-radius: 1rem;
		background: var(--panel);
		box-shadow: var(--frame-shadow);
	}

	figure {
		overflow: hidden;
		border-radius: 0.25rem;
	}

	.gallery a {
		display: block;
	}

	.screenshot {
		width: 100%;
		outline: 1px solid oklch(1 0 0 / 10%);
		outline-offset: -1px;
	}

	.stack {
		padding-top: 1.25rem;
		border-top: 1px solid var(--line);
	}

	@media (min-width: 48rem) {
		h3 {
			font-size: 2.75rem;
		}
	}

	@media (min-width: 64rem) {
		.feature {
			padding-inline: 2rem;
		}

		h3 {
			font-size: 3.25rem;
		}
	}

	@media (min-width: 80rem) {
		.feature {
			grid-template-columns: minmax(30rem, 34rem) minmax(0, 1fr);
			padding-inline: 2.75rem;
		}

		.copy {
			position: sticky;
			top: 2.5rem;
		}

		.gallery {
			margin-left: 0;
		}

		.stack {
			grid-column: 1 / -1;
		}

		.reverse {
			grid-template-columns: minmax(0, 1fr) minmax(30rem, 34rem);
		}

		.reverse .copy-column {
			order: 2;
		}

		.reverse .gallery-column {
			order: 1;
		}

		.reverse .gallery {
			margin-right: 0;
			margin-left: auto;
		}

		.reverse .stack {
			order: 3;
		}
	}
</style>
