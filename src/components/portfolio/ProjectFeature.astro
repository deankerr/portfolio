---
import type { Project, ProjectScreenshot } from '../../types/portfolio';
import Prose from './Prose.astro';
import Screenshot from './Screenshot.astro';

interface Props {
	project: Project;
	screenshots: ProjectScreenshot[];
}

const { project, screenshots } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<article class="grid gap-x-11 gap-y-9 border-t border-line py-9 lg:grid-cols-2">
	<div>
		<h3 class="text-3xl leading-none font-medium tracking-tight text-balance lg:text-5xl">
			{project.name}
		</h3>
		<p class="mt-2.5 text-base text-accent">{project.kicker}</p>
		<p class="mt-1.5 font-mono text-xs text-ink-faint">{project.date}</p>
		<div class="mt-5">
			<Prose><slot /></Prose>
		</div>
		<a class="mt-6 inline-block font-mono text-sm" href={project.repo} {...externalLink}>github ↗</a
		>
	</div>

	<div class="mx-auto grid w-full max-w-[40rem] content-start gap-4 lg:mx-0">
		{
			screenshots.map((screenshot) => (
				<div class="rounded-md bg-panel p-3 shadow-frame">
					<figure class="overflow-hidden rounded">
						<Screenshot screenshot={screenshot} gallery={project.name} width={640} />
					</figure>
				</div>
			))
		}
	</div>

	<div class="border-t border-line pt-5 lg:col-span-full">
		<p class="font-mono text-xs font-medium tracking-widest text-ink-faint lowercase">stack</p>
		<ul class="mt-4 grid gap-x-9 gap-y-3 lg:grid-cols-3">
			{
				project.stack.map((item) => (
					<li class="text-sm leading-normal text-ink-soft">
						<strong class="font-mono text-xs font-semibold text-ink">{item.name}</strong>
						{item.note && <>: {item.note}</>}
					</li>
				))
			}
		</ul>
	</div>
</article>
