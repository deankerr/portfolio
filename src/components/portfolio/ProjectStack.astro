---
import type { Project } from '../../types/portfolio';

interface Props {
	items: Project['stack'];
	layout?: 'compact' | 'wide';
	tone?: 'page' | 'panel';
}

const { items, layout = 'compact', tone = 'page' } = Astro.props;
---

<div>
	<p
		class:list={[
			'font-mono text-xs font-medium tracking-widest lowercase',
			tone === 'panel' ? 'text-panel-ink/60' : 'text-ink-faint',
		]}
	>
		stack
	</p>
	<ul
		class:list={[
			layout === 'wide'
				? 'mt-4 grid gap-x-9 gap-y-3 sm:grid-cols-2 lg:grid-cols-3'
				: 'mt-3 grid gap-2',
		]}
	>
		{
			items.map((item) => (
				<li
					class:list={[
						'text-sm leading-normal',
						tone === 'panel' ? 'text-panel-ink/70' : 'text-ink-soft',
					]}
				>
					<strong
						class:list={[
							'font-mono text-xs font-semibold',
							tone === 'panel' ? 'text-panel-ink' : 'text-ink',
						]}
					>
						{item.name}
					</strong>
					{item.note && <>: {item.note}</>}
				</li>
			))
		}
	</ul>
</div>
