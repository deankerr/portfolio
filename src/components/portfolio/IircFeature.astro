---
import type { Project, ProjectScreenshot } from '../../types/portfolio';
import Prose from './Prose.astro';
import Screenshot from './Screenshot.astro';

interface Props {
	app: Project;
	library: Project;
	screenshot: ProjectScreenshot;
}

const { app, library, screenshot } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<section class="border-t border-line pt-9 pb-14 lg:px-8 xl:px-11" aria-labelledby="iirc-title">
	<div class="grid gap-x-11 gap-y-10 md:grid-cols-2">
		<div>
			<h3
				id="iirc-title"
				class="text-3xl leading-none font-medium tracking-tight text-balance md:text-4xl lg:text-5xl"
			>
				{app.name}
			</h3>
			<p class="mt-2.5 text-base text-accent">{app.kicker}</p>
			<p class="mt-1.5 font-mono text-xs text-ink-faint">{app.date}</p>
			<div class="mt-8 text-base">
				<Prose><slot name="app" /></Prose>
			</div>
			<div class="mt-6 max-w-[58ch]">
				<div>
					<p class="font-mono text-xs font-medium tracking-widest text-ink-faint lowercase">
						stack
					</p>
					<ul class="mt-3 grid gap-2">
						{
							app.stack.map((item) => (
								<li class="text-sm leading-normal text-ink-soft">
									<strong class="font-mono text-xs font-semibold text-ink">{item.name}</strong>
									{item.note && <>: {item.note}</>}
								</li>
							))
						}
					</ul>
				</div>
			</div>
			<div class="mt-6 max-w-[34rem] rounded-2xl bg-panel p-3 shadow-frame">
				<figure class="overflow-hidden rounded">
					<Screenshot screenshot={screenshot} gallery="iirc" width={544} />
				</figure>
			</div>
			<a class="mt-6 inline-block font-mono text-sm" href={app.repo} {...externalLink}>github ↗</a>
		</div>

		<div>
			<article class="rounded-xl bg-surface-subtle p-5 ring-1 ring-line md:sticky md:top-10 md:p-6">
				<h4 class="font-mono text-lg font-bold wrap-anywhere">{library.name}</h4>
				<p class="mt-2 text-base text-accent">{library.kicker}</p>
				<div class="mt-4 text-base">
					<Prose><slot name="library" /></Prose>
				</div>
				<div class="mt-5">
					<div>
						<p class="font-mono text-xs font-medium tracking-widest text-ink-faint lowercase">
							stack
						</p>
						<ul class="mt-3 grid gap-2">
							{
								library.stack.map((item) => (
									<li class="text-sm leading-normal text-ink-soft">
										<strong class="font-mono text-xs font-semibold text-ink">{item.name}</strong>
										{item.note && <>: {item.note}</>}
									</li>
								))
							}
						</ul>
					</div>
				</div>
				<div class="mt-6 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-sm">
					{
						library.live && (
							<a href={library.live} {...externalLink}>
								npm ↗
							</a>
						)
					}
					<a href={library.repo} {...externalLink}>github ↗</a>
				</div>
			</article>
		</div>
	</div>
</section>
