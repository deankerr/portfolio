---
import { Image } from 'astro:assets';
import type { Project, ProjectScreenshot } from '../../types/portfolio';
import ProjectStack from './ProjectStack.astro';
import Prose from './Prose.astro';

interface Props {
	app: Project;
	library: Project;
	screenshot: ProjectScreenshot;
}

const { app, library, screenshot } = Astro.props;
const externalLink = { target: '_blank', rel: 'noopener' };
---

<section class="section" aria-labelledby="iirc-title">
	<div class="layout">
		<div class="app">
			<h3 id="iirc-title">{app.name}</h3>
			<p class="kicker">{app.kicker}</p>
			<p class="date">{app.date}</p>
			<div class="app-description">
				<Prose><slot name="app" /></Prose>
			</div>
			<div class="app-stack">
				<ProjectStack items={app.stack} />
			</div>
			<div class="frame">
				<figure>
					<a href={screenshot.src.src} class="glightbox" data-gallery="iirc">
						<Image
							src={screenshot.src}
							alt={screenshot.alt}
							widths={[480, 720, 1080, 1440]}
							sizes="min(34rem, 92vw)"
							loading="lazy"
							quality={88}
							class="screenshot"
						/>
					</a>
				</figure>
			</div>
			<a class="project-link" href={app.repo} {...externalLink}>github ↗</a>
		</div>

		<div class="library-column">
			<article class="library">
				<h4>{library.name}</h4>
				<p class="library-kicker">{library.kicker}</p>
				<div class="library-description">
					<Prose><slot name="library" /></Prose>
				</div>
				<div class="library-stack">
					<ProjectStack items={library.stack} />
				</div>
				<div class="library-links">
					{
						library.live && (
							<a href={library.live} {...externalLink}>
								npm ↗
							</a>
						)
					}
					<a href={library.repo} {...externalLink}>github ↗</a>
				</div>
			</article>
		</div>
	</div>
</section>

<style>
	.section {
		padding-block: 2.25rem 3.5rem;
		border-top: 1px solid var(--line);
	}

	.layout {
		display: grid;
		gap: 2.5rem 2.75rem;
	}

	h3 {
		font-size: 2.1rem;
		font-weight: 500;
		letter-spacing: -0.02em;
		line-height: 0.95;
	}

	.kicker {
		margin-top: 0.625rem;
		color: var(--accent);
		font-size: 0.98rem;
	}

	.date {
		margin-top: 0.375rem;
		color: var(--ink-faint);
		font-family: var(--font-mono);
		font-size: 0.72rem;
	}

	.app-description {
		margin-top: 2rem;
		font-size: 0.95rem;
	}

	.app-stack {
		max-width: 58ch;
		margin-top: 1.5rem;
	}

	.frame {
		max-width: 34rem;
		margin-top: 1.5rem;
		padding: 0.75rem;
		border-radius: 1rem;
		background: var(--panel);
		box-shadow: var(--frame-shadow);
	}

	figure {
		overflow: hidden;
		border-radius: 0.25rem;
	}

	figure a {
		display: block;
	}

	.screenshot {
		width: 100%;
		outline: 1px solid oklch(1 0 0 / 10%);
		outline-offset: -1px;
	}

	.project-link {
		display: inline-block;
		margin-top: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.82rem;
	}

	.library {
		padding: 1.25rem;
		border-radius: 0.75rem;
		background: rgb(28 27 23 / 2.5%);
		box-shadow: 0 0 0 1px var(--line);
	}

	:global(html[data-theme='dark']) .library {
		background: rgb(233 231 223 / 2.5%);
	}

	h4 {
		font-family: var(--font-mono);
		font-size: 1.1rem;
		font-weight: 700;
		overflow-wrap: anywhere;
	}

	.library-kicker {
		margin-top: 0.5rem;
		color: var(--accent);
		font-size: 0.95rem;
	}

	.library-description {
		margin-top: 1rem;
		font-size: 0.95rem;
	}

	.library-stack {
		margin-top: 1.25rem;
	}

	.library-links {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.5rem 1.5rem;
		margin-top: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.82rem;
	}

	@media (min-width: 48rem) {
		.layout {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		h3 {
			font-size: 2.75rem;
		}

		.library {
			position: sticky;
			top: 2.5rem;
			padding: 1.5rem;
		}
	}

	@media (min-width: 64rem) {
		.section {
			padding-inline: 2rem;
		}

		h3 {
			font-size: 3.25rem;
		}
	}

	@media (min-width: 80rem) {
		.section {
			padding-inline: 2.75rem;
		}
	}
</style>
