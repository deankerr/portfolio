---
import HeroDiagram from '../diagrams/Hero.astro';
---

<section id="top" class="hero grid items-center gap-9 border-t border-line py-9 pb-12">
	<div>
		<h1
			class="max-w-[22ch] text-4xl leading-none font-bold tracking-tight text-balance md:text-5xl lg:text-6xl"
		>
			I build tooling for people who work directly with LLMs and inference.
		</h1>
		<p class="mt-6 max-w-[54ch] text-base leading-relaxed text-ink-soft">
			Everything below is built solo, in TypeScript — edge infrastructure, streaming runtimes,
			protocol libraries, and the analysis tooling on top. I observe the model catalog, build client
			runtimes against it, and operate inference in production.
		</p>
	</div>
	<div class="mx-auto w-full max-w-sm text-diagram lg:max-w-none" aria-hidden="true">
		<HeroDiagram />
	</div>
</section>

<style>
	.hero {
		@media (min-width: 64rem) {
			grid-template-columns: minmax(0, 3fr) minmax(18rem, 2fr);
		}
	}
</style>
