---
import HeroDiagram from '../diagrams/Hero.astro';
---

<section id="top" class="hero">
	<div class="copy">
		<h1>I build tooling for people who work directly with LLMs and inference.</h1>
		<p>
			Everything below is built solo, in TypeScript — edge infrastructure, streaming runtimes,
			protocol libraries, and the analysis tooling on top. It's one thread, running since 2024:
			observing the model catalog, building a client runtime against it, and operating inference in
			production.
		</p>
	</div>
	<div class="diagram" aria-hidden="true">
		<HeroDiagram />
	</div>
</section>

<style>
	.hero {
		display: grid;
		align-items: center;
		gap: 2.25rem;
		padding-block: 2.25rem 3rem;
		border-top: 1px solid var(--line);
	}

	h1 {
		max-width: 22ch;
		font-size: 2.35rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.02;
		text-wrap: balance;
	}

	p {
		max-width: 54ch;
		margin-top: 1.5rem;
		color: var(--ink-soft);
		font-size: 1.02rem;
		line-height: 1.6;
	}

	.diagram {
		width: 100%;
		max-width: 24rem;
		margin-inline: auto;
		color: var(--diagram);
	}

	@media (min-width: 48rem) {
		h1 {
			font-size: 3rem;
		}
	}

	@media (min-width: 64rem) {
		.hero {
			grid-template-columns: minmax(0, 3fr) minmax(18rem, 2fr);
		}

		h1 {
			font-size: 3.75rem;
		}

		.diagram {
			max-width: none;
		}
	}
</style>
