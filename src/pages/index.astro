---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

import esuiteArtifactShot from '../assets/esuite-1.png';
import esuiteModelsShot from '../assets/esuite-2.png';
import igArtifactShot from '../assets/ig-1.png';
import igFeedShot from '../assets/ig-2.png';
import iircShot from '../assets/iirc-1.png';
import orcaEndpointsShot from '../assets/orca-1.png';
import orcaMonitorShot from '../assets/orca-2.png';
import tetraMarkdownShot from '../assets/tetra-1.png';
import tetraImageShot from '../assets/tetra-2.png';

import ArchiDiagram from '../components/diagrams/Archi.astro';
import AdvektDiagram from '../components/diagrams/Advekt.astro';
import DurianDiagram from '../components/diagrams/Durian.astro';
import OmuxDiagram from '../components/diagrams/Omux.astro';
import OrbstackSandboxDiagram from '../components/diagrams/OrbstackSandbox.astro';

import Hero from '../components/portfolio/Hero.astro';
import IircFeature from '../components/portfolio/IircFeature.astro';
import Lightbox from '../components/portfolio/Lightbox.astro';
import OrcaFeature from '../components/portfolio/OrcaFeature.astro';
import OtherWorkItem from '../components/portfolio/OtherWorkItem.astro';
import ProjectFeature from '../components/portfolio/ProjectFeature.astro';
import SiteFooter from '../components/portfolio/SiteFooter.astro';
import SiteHeader from '../components/portfolio/SiteHeader.astro';
import SiteInteractions from '../components/portfolio/SiteInteractions.astro';
import type { ContactDetails, ProjectScreenshot } from '../types/portfolio';

const contact: ContactDetails = {
	github: 'https://github.com/deankerr',
	discord: 'ultra.doan',
	email: 'dean.kerr@gmail.com',
};

const projectEntries = await getCollection('projects');

async function loadProject(id: string) {
	const entry = projectEntries.find((project) => project.id === id);
	if (!entry) throw new Error(`content/projects/${id}.md not found`);

	const { Content } = await render(entry);
	return {
		project: { id, ...entry.data },
		Content,
	};
}

const orca = await loadProject('orca');
const orcaScreenshots = [
	{
		src: orcaEndpointsShot,
		alt: 'ORCA endpoints grid showing OpenRouter models, providers, pricing, modalities, features, and context windows',
	},
	{
		src: orcaMonitorShot,
		alt: 'ORCA monitor timeline showing recent pricing changes and new endpoints across providers',
	},
];

const featuredProjects = await Promise.all(['tetra', 'ig', 'e-suite'].map(loadProject));
const featuredScreenshots: Record<string, ProjectScreenshot[]> = {
	tetra: [
		{
			src: tetraMarkdownShot,
			alt: 'tetra answering a Node.js workers question with a code block and a comparison table',
		},
		{
			src: tetraImageShot,
			alt: 'tetra chat session with an AI-generated pixel-art planet beside a settings panel of model, tool, and provider options',
		},
	],
	ig: [
		{
			src: igArtifactShot,
			alt: 'ig artifact detail view showing a generated PSX-style kaiju image beside its prompt, model, seed, cost, and duration',
		},
		{
			src: igFeedShot,
			alt: 'ig artifact feed: a dense grid of AI-generated images',
		},
	],
	'e-suite': [
		{
			src: esuiteArtifactShot,
			alt: 'e-suite conversation with a live-rendered HTML artifact, a retro terminal interface, beside the chat',
		},
		{
			src: esuiteModelsShot,
			alt: 'e-suite model picker filtered to "flash", listing available models with per-token pricing',
		},
	],
};

const iirc = await loadProject('iirc');
const iircLibrary = await loadProject('iirc-lib');
const iircScreenshot = {
	src: iircShot,
	alt: 'iirc web client: a buffer sidebar beside two channel panels, a names list and a live #iirc-client conversation',
};

const supportingProjects = await Promise.all(
	['advekt', 'omux', 'durian', 'orbstack-sandbox', 'archi'].map(loadProject),
);
const supportingDiagrams: Record<string, (props: Record<string, never>) => unknown> = {
	advekt: AdvektDiagram,
	omux: OmuxDiagram,
	durian: DurianDiagram,
	'orbstack-sandbox': OrbstackSandboxDiagram,
	archi: ArchiDiagram,
};
---

<Layout>
	<div class="mx-auto w-full max-w-6xl px-5 md:px-6 lg:px-8">
		<SiteHeader contact={contact} />
		<main>
			<Hero />

			<OrcaFeature project={orca.project} screenshots={orcaScreenshots}>
				<orca.Content />
			</OrcaFeature>

			<section aria-label="Selected work">
				{
					featuredProjects.map(({ project, Content }) => (
						<ProjectFeature project={project} screenshots={featuredScreenshots[project.id] ?? []}>
							<Content />
						</ProjectFeature>
					))
				}
			</section>

			<IircFeature app={iirc.project} library={iircLibrary.project} screenshot={iircScreenshot}>
				<Fragment slot="app"><iirc.Content /></Fragment>
				<Fragment slot="library"><iircLibrary.Content /></Fragment>
			</IircFeature>

			<section class="border-t border-line pt-7 pb-4" aria-label="Other work">
				<p class="font-mono text-xs font-medium tracking-widest text-ink-faint uppercase">
					other work
				</p>
				{
					supportingProjects.map(({ project, Content }) => {
						const Diagram = supportingDiagrams[project.id];
						return (
							<OtherWorkItem project={project}>
								<Content />
								{Diagram && (
									<Fragment slot="diagram">
										<Diagram />
									</Fragment>
								)}
							</OtherWorkItem>
						);
					})
				}
			</section>
		</main>
		<SiteFooter contact={contact} />
	</div>

	<SiteInteractions />
	<Lightbox />
</Layout>
