---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Screenshots live in src/assets so Astro optimizes them (AVIF/WebP + srcset).
import orcaShot from '../assets/orca-endpoints-grid.png';
import orcaMonitorShot from '../assets/orca-monitor.png';
import orcaApiShot from '../assets/orca-api.png';
import tetraMarkdownShot from '../assets/tetra-markdown-chat.png';
import tetraImageShot from '../assets/tetra-image-chat.png';
import igFeedShot from '../assets/ig-image-feed.png';
import igBatchShot from '../assets/ig-image-batch.png';
import esuiteArtifactShot from '../assets/e-suite-artifact-chat.png';
import esuiteGenShot from '../assets/e-suite-generations.png';
import iircShot from '../assets/iirc.png';

// The supporting cast has no screenshots — each gets a wireframe diagram
// keyed to its core idea instead, drawn in currentColor + accent.
import AdvektDiagram from '../components/diagrams/Advekt.astro';
import OmuxDiagram from '../components/diagrams/Omux.astro';
import DurianDiagram from '../components/diagrams/Durian.astro';
import OrbstackSandboxDiagram from '../components/diagrams/OrbstackSandbox.astro';
import ArchiDiagram from '../components/diagrams/Archi.astro';

// Contact — single lane, header and footer share it. The discord handle isn't
// a URL; those render as copy-to-clipboard buttons instead of links.
const contact = {
	github: 'https://github.com/deankerr',
	discord: 'ultra.doan',
	email: 'dean.kerr@gmail.com',
};

// External links open beside the page, not over it.
const ext = { target: '_blank', rel: 'noopener' };

// Copy comes from content/projects/*.md (schema in src/content.config.ts).
// The page owns order and grouping; screenshots stay here because they're
// page furniture, not project content.
const entries = await getCollection('projects');

async function load(id: string) {
	const entry = entries.find((e) => e.id === id);
	if (!entry) throw new Error(`content/projects/${id}.md not found`);
	const { Content } = await render(entry);
	return { id, ...entry.data, Content };
}

// The anchor project gets its own dark panel; everything leads with OpenRouter.
const orca = await load('orca');
const orcaShots = {
	hero: {
		src: orcaShot,
		alt: 'ORCA endpoints grid showing OpenRouter models, providers, pricing, features, and context windows',
	},
	// Two supporting shots below the hero grid — the monitor makes the
	// "catalog in motion" pitch literal.
	supports: [
		{
			src: orcaMonitorShot,
			alt: 'ORCA monitor timeline showing recent pricing, max-output, and endpoint changes across providers over time',
		},
		{
			src: orcaApiShot,
			alt: 'ORCA API documentation page with a sample JSON response of OpenRouter models and endpoints',
		},
	],
};

// The proof trail, in page order, with their shots.
const majors = await Promise.all(['tetra', 'ig', 'e-suite'].map(load));
const majorShots: Record<string, { src: ImageMetadata; alt: string }[]> = {
	tetra: [
		{
			src: tetraMarkdownShot,
			alt: 'tetra answering a Node.js workers question with a code block and a comparison table',
		},
		{
			src: tetraImageShot,
			alt: 'tetra chat session with an inline AI-generated image from a PSX-style prompt',
		},
	],
	ig: [
		{
			src: igFeedShot,
			alt: 'ig artifact feed: a dense grid of AI-generated images',
		},
		{
			src: igBatchShot,
			alt: 'ig artifact detail view showing a generated image beside its prompt, model, seed, cost, and duration',
		},
	],
	'e-suite': [
		{
			src: esuiteArtifactShot,
			alt: 'e-suite conversation with a live-rendered HTML artifact, an intercepted-transmission interface, beside the chat',
		},
		{
			src: esuiteGenShot,
			alt: 'e-suite image generation view showing a batch of four portrait renders from a single prompt',
		},
	],
};

// iirc — the app is the project (it owns the section header); iirc-lib is its
// protocol library, presented as a sub-project alongside. iirc carries the shot.
const iirc = await load('iirc');
const iircLib = await load('iirc-lib');
const iircShotAlt =
	'iirc web client: a buffer sidebar beside two channel panels, a names list and a live #iirc-client conversation';

// Texture, not co-equal — but the same two-paragraph treatment, no shots.
const supporting = await Promise.all(
	['advekt', 'omux', 'durian', 'orbstack-sandbox', 'archi'].map(load),
);
const diagrams: Record<string, (props: Record<string, never>) => unknown> = {
	advekt: AdvektDiagram,
	omux: OmuxDiagram,
	durian: DurianDiagram,
	'orbstack-sandbox': OrbstackSandboxDiagram,
	archi: ArchiDiagram,
};

// Shared class lanes. One uppercase eyebrow style, used sparingly (ORCA panel
// and the "other work" divider); everything else identifies itself in normal case.
const label = 'font-mono text-[0.72rem] font-medium uppercase tracking-[0.16em] text-ink-faint';
const headerLink = 'font-mono text-[0.84rem] lowercase no-underline hover:underline';
---

<Layout>
	<div class="mx-auto w-full max-w-[1400px] px-[clamp(1.25rem,3vw,2rem)]">
		<!-- Header — quiet; the work should be the loudest thing on the page. -->
		<header class="flex items-center justify-between gap-6 py-5">
			<a class="font-semibold whitespace-nowrap lowercase no-underline" href="#top">dean kerr</a>
			<nav class="flex items-center gap-4 sm:gap-5" aria-label="Contact links">
				<a class={headerLink} href={contact.github} {...ext}>github</a>
				<button
					data-copy={contact.discord}
					title={`copy discord handle: ${contact.discord}`}
					class={`${headerLink} cursor-pointer hover:underline active:translate-y-px`}
				>
					discord
				</button>
				<a class={headerLink} href={`mailto:${contact.email}`}>email</a>
				<button
					data-theme-toggle
					aria-label="Toggle color theme"
					class="cursor-pointer font-mono text-[0.84rem] lowercase text-ink-faint transition-colors hover:text-ink"
				>
					<span class="[[data-theme=dark]_&]:hidden">dark</span>
					<span class="hidden [[data-theme=dark]_&]:inline">light</span>
				</button>
			</nav>
		</header>

		<!-- Hero — one claim, one compact proof list. -->
		<section
			id="top"
			class="grid items-end gap-9 border-t border-line pt-9 pb-12 lg:grid-cols-[minmax(0,1fr)_minmax(260px,0.36fr)]"
		>
			<div>
				<h1
					class="max-w-[22ch] text-[clamp(2.5rem,5vw,4.5rem)] leading-[1.02] font-bold tracking-[-0.02em] text-balance"
				>
					I build tooling for people who work directly with LLMs and inference.
				</h1>
			</div>
			<ul class="pb-1.5 font-mono text-[0.8rem] text-ink-soft" aria-label="Focus areas">
				<li class="border-b border-line py-2.5">OpenRouter catalog analysis</li>
				<li class="border-b border-line py-2.5">Inference runtime design</li>
				<li class="border-b border-line py-2.5">Edge orchestration</li>
			</ul>
		</section>

		<!-- ORCA — the anchor, in its own dark panel so the screenshot has a home. -->
		<section class="border-t border-line pt-7 pb-14" aria-labelledby="orca-title">
			<article class="rounded-lg bg-panel p-[clamp(1.5rem,3vw,2.75rem)] text-panel-ink">
				<p
					class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.16em] text-panel-ink/60"
				>
					{orca.kicker}
				</p>
				<h2
					id="orca-title"
					class="mt-4 text-[clamp(3.75rem,7vw,7rem)] leading-[0.85] font-medium tracking-[-0.02em]"
				>
					{orca.name}
				</h2>
				<div class="md-prose md-prose-panel mt-6">
					<orca.Content />
				</div>
				<div class="mt-7 flex flex-wrap items-baseline gap-x-7 gap-y-2 font-mono text-[0.85rem]">
					{
						orca.live && (
							<a href={orca.live} {...ext}>
								{new URL(orca.live).host} ↗
							</a>
						)
					}
					<a href={orca.repo} {...ext}>github ↗</a>
				</div>
				<figure class="mt-8 overflow-hidden rounded-md">
					<a href={orcaShots.hero.src.src} class="glightbox block" data-gallery="orca">
						<Image
							src={orcaShots.hero.src}
							alt={orcaShots.hero.alt}
							widths={[640, 960, 1320, 1980, 2640]}
							sizes="(min-width: 1400px) 1320px, 92vw"
							quality={90}
							class="w-full"
						/>
					</a>
				</figure>
				{/* Supporting portraits — the catalog in motion, and the API behind it. */}
				<div class="mt-4 grid items-start gap-4 sm:grid-cols-2">
					{
						orcaShots.supports.map((shot) => (
							<figure class="overflow-hidden rounded-md">
								<a href={shot.src.src} class="glightbox block " data-gallery="orca">
									<Image
										src={shot.src}
										alt={shot.alt}
										widths={[432, 648, 864, 1280]}
										sizes="(min-width: 640px) 640px, 92vw"
										loading="lazy"
										quality={90}
										class="w-full"
									/>
								</a>
							</figure>
						))
					}
				</div>
			</article>
		</section>

		<!-- The proof trail. Each major shares one split layout for rhythm —
		     text-left, shots-right — except ig, which flips so the layout
		     alternates. Copy outruns the shots, so the shots stick. -->
		<section aria-label="Selected work">
			{
				majors.map((m) => (
					<article
						class={`grid gap-9 border-t border-line py-9 ${
							m.id === 'ig'
								? 'lg:grid-cols-[minmax(0,1fr)_minmax(300px,0.65fr)]'
								: 'lg:grid-cols-[minmax(300px,0.65fr)_minmax(0,1fr)]'
						}`}
					>
						<div class={m.id === 'ig' ? 'lg:order-2' : ''}>
							<h3 class="text-[clamp(2.6rem,4.5vw,4.5rem)] leading-[0.9] font-medium tracking-[-0.02em]">
								{m.name}
							</h3>
							<p class="mt-3 text-[1.02rem] text-accent">{m.kicker}</p>
							<div class="md-prose mt-5">
								<m.Content />
							</div>
							<a class="mt-6 inline-block font-mono text-[0.85rem]" href={m.repo} {...ext}>
								github ↗
							</a>
						</div>
						{/* Same dark-chrome treatment as the ORCA panel, stacked vertically;
						    landscape shots want the full lane. self-start + sticky so the
						    shots stay in view while the longer copy scrolls. */}
						<div
							class={`grid gap-4 self-start lg:sticky lg:top-10 ${m.id === 'ig' ? 'lg:order-1' : ''}`}
						>
							{(majorShots[m.id] ?? []).map((shot) => (
								<div class="rounded-lg bg-panel p-[clamp(0.75rem,1.5vw,1.25rem)] shadow-frame">
									<figure class="overflow-hidden rounded-md">
										<a href={shot.src.src} class="glightbox block " data-gallery={m.name}>
											<Image
												src={shot.src}
												alt={shot.alt}
												widths={[640, 960, 1280, 1680]}
												sizes="(min-width: 1024px) 60vw, 92vw"
												loading="lazy"
												quality={90}
												class="w-full"
											/>
										</a>
									</figure>
								</div>
							))}
						</div>
					</article>
				))
			}
		</section>

		<!-- iirc — the app is the project and owns the major header (matching the
		     projects above). iirc-lib sits beside it as a sub-project: its own
		     smaller card, so the hierarchy reads app-then-library, not two peers.
		     The app carries the one screenshot; it's the weakest shot in the set,
		     so it stays small and expands on click. -->
		<section class="border-t border-line pt-9 pb-14" aria-labelledby="iirc-title">
			<h3
				id="iirc-title"
				class="text-[clamp(2.6rem,4.5vw,4.5rem)] leading-[0.9] font-medium tracking-[-0.02em]"
			>
				iirc
			</h3>
			<p class="mt-3 text-[1.02rem] text-accent">{iirc.kicker}</p>

			<div class="mt-8 grid items-start gap-x-11 gap-y-10 md:grid-cols-2">
				{/* The app — flows straight from the section header, no repeated name. */}
				<div>
					<div class="md-prose text-[0.95rem]">
						<iirc.Content />
					</div>
					<div class="mt-6 rounded-md bg-panel p-[clamp(0.5rem,1vw,0.85rem)] shadow-frame">
						<figure class="overflow-hidden rounded">
							<a href={iircShot.src} class="glightbox block" data-gallery="iirc">
								<Image
									src={iircShot}
									alt={iircShotAlt}
									widths={[480, 720, 1080, 1440]}
									sizes="(min-width: 768px) 46vw, 92vw"
									loading="lazy"
									quality={88}
									class="w-full"
								/>
							</a>
						</figure>
					</div>
					<a class="mt-6 inline-block font-mono text-[0.82rem]" href={iirc.repo} {...ext}>
						github ↗
					</a>
				</div>

				{
					/* The library — a sub-project, so it's a named card set apart from the
				    app's flowing column. */
				}
				<article class="rounded-lg border border-line bg-ink/[0.025] p-[clamp(1.1rem,2vw,1.6rem)]">
					<h4 class="font-mono text-[1.1rem] font-bold break-words">{iircLib.name}</h4>
					<p class="mt-2 text-[0.95rem] text-accent">{iircLib.kicker}</p>
					<div class="md-prose mt-4 text-[0.95rem]">
						<iircLib.Content />
					</div>
					<div class="mt-6 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono text-[0.82rem]">
						<a href={iircLib.live} {...ext}> npm ↗ </a>
						<a href={iircLib.repo} {...ext}> github ↗ </a>
					</div>
				</article>
			</div>
		</section>

		<!-- Other work — no shots, so the copy carries each entry alone. -->
		<section class="border-t border-line pt-7 pb-4" aria-label="Other work">
			<p class={label}>other work</p>
			{
				supporting.map((s) => {
					const Diagram = diagrams[s.id];
					return (
						<article class="grid gap-x-10 gap-y-4 border-b border-line py-8 last:border-b-0 md:grid-cols-[12rem_minmax(0,1fr)] lg:grid-cols-[11rem_minmax(0,1.5fr)_minmax(0,1fr)]">
							<div class="self-start md:sticky md:top-10">
								<h3 class="font-mono text-[1.05rem] font-bold">{s.name}</h3>
								<p class="mt-2 text-[0.92rem] leading-snug text-ink-soft">{s.kicker}</p>
								<p class="mt-1.5 font-mono text-[0.72rem] text-ink-faint">{s.date}</p>
								<a class="mt-3 inline-block font-mono text-[0.8rem]" href={s.repo} {...ext}>
									github ↗
								</a>
							</div>
							<div class="md-prose max-w-[68ch] text-[0.95rem]">
								<s.Content />
							</div>
							{/* Concept diagram in place of a screenshot — decorative, so
							    hidden from AT; the diagram gray keeps it quieter than the prose.
							    viewBox-driven, so it fills whatever lane the grid gives it. */}
							{Diagram && (
								<div
									class="mx-auto w-full max-w-[26rem] self-start text-diagram md:col-start-2 lg:sticky lg:top-10 lg:col-start-auto lg:max-w-none"
									aria-hidden="true"
								>
									<Diagram />
								</div>
							)}
						</article>
					);
				})
			}
		</section>

		<footer
			class="mt-16 flex flex-wrap items-baseline justify-between gap-4 border-t border-line py-7 font-mono text-[0.8rem] text-ink-faint"
		>
			<span>dean kerr</span>
			<nav class="flex flex-wrap gap-x-5 gap-y-1" aria-label="Contact links">
				<a class="no-underline hover:underline" href={contact.github} {...ext}>github</a>
				<button
					data-copy={contact.discord}
					title="copy discord handle"
					class="cursor-pointer whitespace-nowrap no-underline hover:underline active:translate-y-px"
				>
					discord · {contact.discord}
				</button>
				<a class="whitespace-nowrap no-underline hover:underline" href={`mailto:${contact.email}`}
					>{contact.email}</a
				>
			</nav>
		</footer>
	</div>
</Layout>

<script>
	// Flip theme and persist; the inline script in Layout reads it back on load.
	document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
		const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
		document.documentElement.dataset.theme = next;
		localStorage.setItem('theme', next);
	});

	// Discord handles aren't URLs — clicking copies the handle, with brief feedback.
	for (const el of document.querySelectorAll<HTMLButtonElement>('[data-copy]')) {
		el.addEventListener('click', async () => {
			await navigator.clipboard.writeText(el.dataset.copy ?? '');
			const original = el.textContent;
			el.textContent = 'copied';
			setTimeout(() => {
				el.textContent = original;
			}, 1200);
		});
	}
</script>

<script>
	// Click any screenshot to open it full-size; each project's shots form one
	// gallery so the lightbox pages between them (Vite bundles the lib + CSS).
	import GLightbox from 'glightbox';
	import 'glightbox/dist/css/glightbox.min.css';

	GLightbox({
		selector: '.glightbox',
		loop: true,
		// No click-to-zoom — the shots already open near full-size, and the extra
		// zoom just nudges the image sideways instead of enlarging it.
		zoomable: false,
		// Snappy fade instead of the default slow zoom.
		openEffect: 'fade',
		closeEffect: 'fade',
		slideEffect: 'fade',
	});
</script>

<!-- GLightbox timing is CSS-driven; is:global so it reaches the un-scoped lib DOM. -->
<style is:global>
	.gfadeIn,
	.gfadeOut,
	.gzoomIn,
	.gzoomOut {
		animation-duration: 0.18s !important;
	}
	.goverlay {
		transition-duration: 0.18s !important;
	}
	/* Keep zoomed images off the viewport edges — the lib defaults to 100vh/100%,
	   which reads as "stuck" when the browser and screenshot have similar dims. */
	.gslide-image img {
		max-width: 92vw !important;
		max-height: 88vh !important;
	}
</style>

<!-- Rendered markdown from the projects collection. is:global because Astro's
     scoped styles can't reach <Content /> output; the .md-prose wrapper scopes
     it instead. Color roles are variables so the dark ORCA panel can retint. -->
<style is:global>
	.md-prose {
		--prose-body: var(--ink-soft);
		--prose-strong: var(--ink);
		--prose-label: var(--ink-faint);
	}
	/* Dark chrome variant: panel-ink derivatives, same in both themes. */
	.md-prose-panel {
		--prose-body: rgba(242, 241, 232, 0.72);
		--prose-strong: #f2f1e8;
		--prose-label: rgba(242, 241, 232, 0.55);
	}
	.md-prose p {
		max-width: 58ch;
		color: var(--prose-body);
	}
	.md-prose p + p {
		margin-top: 0.9em;
	}
	.md-prose strong {
		color: var(--prose-strong);
		font-weight: 600;
	}
	.md-prose code {
		font-family: var(--font-mono);
		font-size: 0.85em;
	}
	/* "## Stack" renders as a quiet lowercase mono label, matching the page's
	   lowercase furniture. */
	.md-prose h2 {
		margin-top: 2.2em;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 500;
		text-transform: lowercase;
		letter-spacing: 0.08em;
		color: var(--prose-label);
	}
	/* Stack lists read as a compact block: the bold mono names carry the
	   structure, so no per-row hairlines. */
	.md-prose ul {
		margin-top: 0.7em;
		display: grid;
		gap: 0.55em;
		max-width: 62ch;
	}
	.md-prose li {
		font-size: 0.875em;
		line-height: 1.55;
		color: var(--prose-body);
	}
	.md-prose li strong {
		font-family: var(--font-mono);
		font-size: 0.92em;
	}
</style>
