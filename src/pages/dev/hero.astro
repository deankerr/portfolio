---
import Layout from '../../layouts/Layout.astro';
import Attention from '../../components/diagrams/hero/Attention.astro';
import Diffusion from '../../components/diagrams/hero/Diffusion.astro';
import TokenStream from '../../components/diagrams/hero/TokenStream.astro';
import OrcaHistory from '../../components/diagrams/hero/OrcaHistory.astro';
import TetraState from '../../components/diagrams/hero/TetraState.astro';

const studies = [
	{
		name: 'attention',
		project: 'the mechanism',
		note: 'A row of tokens under a field of quiet arcs. Focus advances token by token, lighting weighted arcs back to what it attends to — always causal, always backward.',
		Study: Attention,
	},
	{
		name: 'diffusion',
		project: 'the generation',
		note: 'A seven-row noise field resolves into a complete diamond outline. Structure emerges from noise rather than arriving as a separate object.',
		Study: Diffusion,
	},
	{
		name: 'token stream',
		project: 'the output',
		note: 'Lines of text-shaped bars type themselves in behind a gliding caret. The last line stops mid-thought and the caret blinks at idle.',
		Study: TokenStream,
	},
];

const retired = [
	{
		name: 'history gains depth',
		project: 'ORCA',
		note: 'Snapshot strips with box chrome — retired: too literal for a hero, needed its caption.',
		Study: OrcaHistory,
	},
	{
		name: 'state outlives its surfaces',
		project: 'tetra',
		note: 'Reader windows with brackets — retired: too literal for a hero, needed its caption.',
		Study: TetraState,
	},
];
---

<Layout title="hero studies · dev" description="Isolated studies for the portfolio hero diagrams.">
	<div class="mx-auto w-full max-w-[1500px] px-[clamp(1.25rem,3vw,2rem)]">
		<header class="flex items-baseline justify-between gap-6 border-b border-line py-5">
			<div class="flex items-baseline gap-3.5">
				<h1 class="font-semibold lowercase">hero studies</h1>
				<span class="font-mono text-[0.78rem] text-ink-faint">dev workbench · not linked</span>
			</div>
			<a class="font-mono text-[0.84rem] lowercase no-underline hover:underline" href="/">← home</a>
		</header>

		<div class="pt-7">
			<p class="max-w-[68ch] text-[0.95rem] leading-[1.6] text-ink-soft">
				How a model works, in three vocabularies: attention arcs, a diffusion field, a streaming
				caret. Attend → generate → stream. Each loop is isolated here so scale, pacing, and visual
				weight can be judged before anything changes in the reel.
			</p>
		</div>

		<section class="grid gap-x-8 gap-y-12 pt-10 pb-16 lg:grid-cols-2 xl:grid-cols-3">
			{
				studies.map(({ name, project, note, Study }) => (
					<article class="border-t border-line pt-6">
						<p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.16em] text-ink-faint">
							{project}
						</p>
						<h2 class="mt-2 text-[1.45rem] leading-tight font-semibold lowercase tracking-[-0.01em]">
							{name}
						</h2>
						<p class="mt-3 min-h-[4.8em] max-w-[48ch] text-[0.9rem] leading-[1.55] text-ink-soft">
							{note}
						</p>
						<div class="mt-5 rounded-md border border-dashed border-line p-4 text-diagram">
							<Study />
						</div>
						<p class="mt-2 text-right font-mono text-[0.7rem] text-ink-faint">canvas 240×144</p>
					</article>
				))
			}
		</section>

		<header class="border-b border-line py-4">
			<h2 class="font-mono text-[0.78rem] lowercase text-ink-faint">retired studies</h2>
		</header>
		<section class="grid gap-x-8 gap-y-12 pt-10 pb-16 lg:grid-cols-2 xl:grid-cols-3">
			{
				retired.map(({ name, project, note, Study }) => (
					<article class="border-t border-line pt-6 opacity-70">
						<p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.16em] text-ink-faint">
							{project}
						</p>
						<h2 class="mt-2 text-[1.45rem] leading-tight font-semibold lowercase tracking-[-0.01em]">
							{name}
						</h2>
						<p class="mt-3 min-h-[4.8em] max-w-[48ch] text-[0.9rem] leading-[1.55] text-ink-soft">
							{note}
						</p>
						<div class="mt-5 rounded-md border border-dashed border-line p-4 text-diagram">
							<Study />
						</div>
						<p class="mt-2 text-right font-mono text-[0.7rem] text-ink-faint">canvas 240×144</p>
					</article>
				))
			}
		</section>
	</div>
</Layout>
